---
// LeadForm — lead capture with required fields and consent checkbox.
// Renders a structural shell. The client script populates content
// when it receives the `funnel:render-lead` custom event.
// Field changes and submit are dispatched back to OrientationFunnel.astro.
// Visual: sage-wash cream section with framed sage panel, night-blue/gold hierarchy.
const whatsappMessage = 'Hola, quiero recibir orientación sobre el Método VIA. Vengo desde la web y me gustaría conversar sobre mi situación.';
const whatsappUrl = `https://wa.me/5491126967602?text=${encodeURIComponent(whatsappMessage)}`;
---

<section
  id="funnel-step-lead"
  class="lead-step surface-sage-wash"
  hidden
  aria-labelledby="lead-heading"
>
  <div class="lead-frame frame-sage">
    <p class="lead-kicker">Último paso</p>
    <h2 id="lead-heading" class="lead-heading" tabindex="-1">
      Completá tus datos para recibir tu orientación.
    </h2>

    <p class="lead-explain">
      Ya terminaste el cuestionario. Ahora completá este último paso para que podamos contactarte y orientarte según tu Mapa Inicial VIA®.
    </p>

    <p class="lead-explain lead-explain-secondary">
      Si preferís conversar primero, también podés seguir por WhatsApp.
    </p>

    <form id="lead-form" class="lead-form" novalidate>
      <!-- Full Name -->
      <div class="form-field">
        <label for="lead-fullname" class="form-label">Nombre y apellido</label>
        <input
          type="text"
          id="lead-fullname"
          class="form-input"
          autocomplete="name"
          required
          aria-describedby="lead-error-fullname"
        />
        <span
          id="lead-error-fullname"
          class="form-error"
          role="alert"
          hidden
        ></span>
      </div>

      <!-- WhatsApp -->
      <div class="form-field">
        <label for="lead-whatsapp" class="form-label">WhatsApp</label>
        <input
          type="tel"
          id="lead-whatsapp"
          class="form-input"
          inputmode="tel"
          autocomplete="tel"
          required
          aria-describedby="lead-error-whatsapp"
        />
        <span
          id="lead-error-whatsapp"
          class="form-error"
          role="alert"
          hidden
        ></span>
      </div>

      <!-- Email (optional) -->
      <div class="form-field">
        <label for="lead-email" class="form-label">
          Correo electrónico <span class="form-label-optional">(opcional)</span>
        </label>
        <input
          type="email"
          id="lead-email"
          class="form-input"
          autocomplete="email"
          aria-describedby="lead-error-email"
        />
        <span
          id="lead-error-email"
          class="form-error"
          role="alert"
          hidden
        ></span>
      </div>

      <!-- Consent -->
      <div class="form-field">
        <label class="form-checkbox-label">
          <input
            type="checkbox"
            id="lead-consent"
            class="form-checkbox focus-ring-cream"
            aria-describedby="lead-error-consent"
          />
          <span class="form-checkbox-text">
            Acepto que Instituto Visión en Acción se contacte conmigo por
            WhatsApp, llamada o correo electrónico en relación con mi consulta,
            y autorizo el tratamiento de mis datos personales para brindarme
            información y una orientación personalizada.
          </span>
        </label>
        <span
          id="lead-error-consent"
          class="form-error"
          role="alert"
          hidden
        ></span>
      </div>

      <!-- Submit Error (network / server) -->
      <div id="lead-submit-error" class="form-error-submit" role="alert" hidden></div>

      <!-- Submit Button -->
      <button
        id="lead-btn-submit"
        class="btn lead-submit-btn focus-ring-gold"
        type="submit"
      >
        Finalizar y recibir orientación
      </button>

      <a
        class="btn lead-whatsapp-btn focus-ring-cream"
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        Prefiero seguir por WhatsApp
      </a>

      <p class="lead-confidentiality">
        ✔ Tu información será tratada con absoluta confidencialidad.
      </p>
    </form>
  </div>
</section>

<script>
  /* ── Lead Form Client Controller ────────────── */

  type LeadRenderData = {
    fullName: string;
    whatsapp: string;
    email: string;
    consent: boolean;
    errors: Record<string, string>;
    submitting: boolean;
    submitError: string;
  };

  const container = document.getElementById('funnel-step-lead')!;
  const form = document.getElementById('lead-form') as HTMLFormElement;
  const inputFullName = document.getElementById(
    'lead-fullname',
  ) as HTMLInputElement;
  const inputWhatsapp = document.getElementById(
    'lead-whatsapp',
  ) as HTMLInputElement;
  const inputEmail = document.getElementById(
    'lead-email',
  ) as HTMLInputElement;
  const inputConsent = document.getElementById(
    'lead-consent',
  ) as HTMLInputElement;
  const btnSubmit = document.getElementById(
    'lead-btn-submit',
  ) as HTMLButtonElement;

  const errorFullName = document.getElementById('lead-error-fullname')!;
  const errorWhatsapp = document.getElementById('lead-error-whatsapp')!;
  const errorEmail = document.getElementById('lead-error-email')!;
  const errorConsent = document.getElementById('lead-error-consent')!;
  const submitErrorEl = document.getElementById('lead-submit-error')!;

  /* ── Render ─────────────────────────────────── */

  function render(data: LeadRenderData) {
    inputFullName.value = data.fullName;
    inputWhatsapp.value = data.whatsapp;
    inputEmail.value = data.email;
    inputConsent.checked = data.consent;

    // Inline errors
    renderError(errorFullName, data.errors.fullName);
    renderError(errorWhatsapp, data.errors.whatsapp);
    renderError(errorEmail, data.errors.email);
    renderError(errorConsent, data.errors.consent);

    // Submit state
    if (data.submitting) {
      btnSubmit.disabled = true;
      btnSubmit.textContent = 'Enviando…';
      submitErrorEl.hidden = true;
    } else {
      btnSubmit.disabled = false;
      btnSubmit.textContent = 'Finalizar y recibir orientación';
      if (data.submitError) {
        submitErrorEl.textContent = data.submitError;
        submitErrorEl.hidden = false;
      } else {
        submitErrorEl.hidden = true;
      }
    }

  }

  function renderError(el: HTMLElement, message: string | undefined) {
    if (message) {
      el.textContent = message;
      el.hidden = false;
    } else {
      el.hidden = true;
    }
  }

  /* ── Clear field error on input ─────────────── */

  function clearFieldError(field: string): void {
    window.dispatchEvent(
      new CustomEvent('funnel:clear-lead-error', { detail: { field } }),
    );
  }

  inputFullName.addEventListener('input', () => {
    clearFieldError('fullName');
    window.dispatchEvent(
      new CustomEvent('funnel:update-lead', {
        detail: { field: 'fullName', value: inputFullName.value },
      }),
    );
  });

  inputWhatsapp.addEventListener('input', () => {
    clearFieldError('whatsapp');
    window.dispatchEvent(
      new CustomEvent('funnel:update-lead', {
        detail: { field: 'whatsapp', value: inputWhatsapp.value },
      }),
    );
  });

  inputEmail.addEventListener('input', () => {
    clearFieldError('email');
    window.dispatchEvent(
      new CustomEvent('funnel:update-lead', {
        detail: { field: 'email', value: inputEmail.value },
      }),
    );
  });

  inputConsent.addEventListener('change', () => {
    clearFieldError('consent');
    window.dispatchEvent(
      new CustomEvent('funnel:update-lead', {
        detail: { field: 'consent', value: inputConsent.checked },
      }),
    );
  });

  /* ── Render event ───────────────────────────── */

  window.addEventListener('funnel:render-lead', ((e: CustomEvent<LeadRenderData>) => {
    container.hidden = false;
    render(e.detail);
  }) as EventListener);

  /* ── Submit ─────────────────────────────────── */

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    window.dispatchEvent(new CustomEvent('funnel:submit-lead'));
  });
</script>

<style>
  .lead-step {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100dvh;
    padding: 2rem;
  }

  .lead-step[data-transition-state='entering'],
  .lead-step[data-transition-state='active'],
  .lead-step[data-transition-state='exiting'] {
    transition:
      opacity 280ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 280ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .lead-step[data-transition-state='entering'] {
    opacity: 0;
    transform: translateY(12px);
  }

  .lead-step[data-transition-state='active'] {
    opacity: 1;
    transform: translateY(0);
  }

  .lead-step[data-transition-state='exiting'] {
    opacity: 0;
    transform: translateY(-8px);
  }

  .lead-frame {
    width: 100%;
    max-width: 580px;
    padding: 2.25rem 2.25rem 1.9rem;
  }

  .lead-kicker {
    margin: 0 0 0.65rem;
    text-align: center;
    font-size: 0.78rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--via-rust, #b46430);
  }

  .lead-heading {
    font-family: var(--ff-heading);
    font-size: clamp(1.5rem, 4vw, 2rem);
    text-align: center;
    margin-bottom: 0.9rem;
    outline: none;
    color: var(--via-night-blue);
  }

  .lead-explain {
    text-align: center;
    font-size: 0.99rem;
    line-height: 1.58;
    color: var(--via-gray-600);
    margin: 0 auto 1.6rem;
    max-width: 480px;
  }

  .lead-explain-secondary {
    margin-top: -0.8rem;
    margin-bottom: 1.6rem;
    color: var(--via-night-blue);
    font-weight: var(--fw-semibold);
  }

  /* ── Form ───────────────────────────────────── */

  .lead-form {
    display: flex;
    flex-direction: column;
    gap: 1.05rem;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .form-label {
    font-family: var(--ff-body);
    font-size: 0.875rem;
    font-weight: var(--fw-semibold);
    color: var(--via-gray-700);
  }

  .form-label-optional {
    font-weight: var(--fw-normal);
    color: var(--via-gray-400);
  }

  .form-input {
    width: 100%;
    padding: 0.8rem 1rem;
    font-family: var(--ff-body);
    font-size: 1rem;
    color: var(--via-gray-800);
    background: var(--via-white);
    border: 2px solid var(--via-gray-200);
    border-radius: var(--radius-md);
    transition: border-color var(--transition-base);
  }

  .form-input:focus {
    border-color: var(--via-gold);
    outline: none;
    box-shadow: 0 0 0 3px rgba(255, 215, 0, 0.18);
  }

  .form-input:focus-visible {
    outline: 2px solid var(--via-night-blue);
    outline-offset: 2px;
  }

  /* ── Error — warm gold-tinted notification ──── */
  .form-error {
    font-size: 0.8125rem;
    font-weight: var(--fw-semibold);
    color: var(--via-night-blue);
    background: rgba(230, 194, 0, 0.12);
    border: 1px solid var(--via-gold);
    border-radius: var(--radius-sm);
    padding: 0.55rem 0.75rem;
    margin-top: 0.2rem;
  }

  .form-error-submit {
    margin-top: 0;
    margin-bottom: 0.25rem;
  }

  /* ── Checkbox ───────────────────────────────── */

  .form-checkbox-label {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    cursor: pointer;
  }

  .form-checkbox {
    flex-shrink: 0;
    width: 1.25rem;
    height: 1.25rem;
    margin-top: 0.125rem;
    accent-color: var(--via-gold);
    cursor: pointer;
  }

  .form-checkbox-text {
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--via-gray-600);
    user-select: none;
  }

  /* ── Submit Button — night-blue fill, gold hover */

  .lead-submit-btn {
    width: 100%;
    font-size: 1.0625rem;
    padding: 0.95rem 1.75rem;
    margin-top: 0.25rem;
    background: var(--via-night-blue);
    color: var(--via-white);
    border-color: var(--via-night-blue);
    box-shadow: 0 2px 10px rgba(26, 39, 68, 0.12);
  }

  .lead-submit-btn:hover {
    background: var(--via-gold);
    color: var(--via-night-blue);
    border-color: var(--via-gold);
    box-shadow: 0 4px 16px rgba(255, 215, 0, 0.22);
  }

  .lead-submit-btn:active {
    transform: translateY(1px);
  }

  .lead-submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .lead-whatsapp-btn {
    width: 100%;
    font-size: 1rem;
    padding: 0.9rem 1.5rem;
    background: var(--via-white);
    color: var(--via-night-blue);
    border-color: rgba(26, 39, 68, 0.22);
    box-shadow: 0 2px 10px rgba(26, 39, 68, 0.07);
  }

  .lead-whatsapp-btn:hover {
    background: rgba(183, 196, 177, 0.2);
    border-color: var(--via-sage-dark);
    box-shadow: 0 4px 16px rgba(26, 39, 68, 0.1);
  }

  .lead-confidentiality {
    margin: 0.15rem 0 0;
    text-align: center;
    font-size: 0.86rem;
    line-height: 1.45;
    color: var(--via-gray-600);
  }

  /* ── Reduced Motion ─────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .lead-step {
      animation: none !important;
      transition: none !important;
    }

    .form-input,
    .lead-submit-btn {
      transition: none !important;
    }

    .lead-submit-btn:active {
      transform: none;
    }
  }

  /* ── Mobile ─────────────────────────────────── */

  @media (max-width: 640px) {
    .lead-step {
      padding: 1.5rem 1rem 1.75rem;
      align-items: flex-start;
      padding-top: 2.25rem;
    }

    .lead-frame {
      padding: 1.5rem 1.1rem 1.35rem;
    }

    .lead-explain {
      font-size: 0.95rem;
    }

    .form-checkbox-text {
      font-size: 0.77rem;
    }
  }
</style>
