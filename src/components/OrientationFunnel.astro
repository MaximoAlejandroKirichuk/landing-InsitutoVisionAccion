---
import Hero from './Hero.astro';
import MethodVIA from './MethodVIA.astro';
import QuizStep from './QuizStep.astro';
import ProcessJourney from './ProcessJourney.astro';
import ThankYou from './ThankYou.astro';
---

<!--
  OrientationFunnel — root wrapper for the funnel flow.
  Owns the step state machine and orchestrates client-side transitions.
  PR 1: hero only. PR 2: quiz engine with progress, validation, and step navigation.
  PR 3: lead form + thank-you + adapter wiring.
-->

<main id="funnel-root" data-step="hero">
  <div id="funnel-announcer" class="sr-only" aria-live="polite" aria-atomic="true"></div>

  <div id="funnel-step-intro" class="funnel-panel funnel-panel-intro" data-transition-state="active">
    <Hero />
  </div>

  <MethodVIA />
  <ProcessJourney />
  <QuizStep />
  <ThankYou />
</main>

<script>
  import {
    initState,
    type FunnelState,
    toggleAnswer,
    setOtherText,
    updateLead,
    setSubmitting,
    setSubmitError,
    advanceTo,
    goBack,
    getQuestionId,
    getQuizStepNumber,
    nextStep,
    buildSubmission,
  } from '../lib/funnelState';
  import { QUIZ_QUESTIONS } from '../lib/quizData';
  import { validateQuizAnswer, validateLead } from '../lib/validation';
  import { submitFunnel } from '../lib/api/index';

  /* ── State ────────────────────────────────── */

  const SUBMISSION_STORAGE_KEY = 'via:funnel:submitted';
  let state: FunnelState = initState();
  let lastAnnouncedQuizStep: number | null = null;

  /* ── Container Helpers ────────────────────── */

  const introEl = document.getElementById('funnel-step-intro')!;
  const quizEl = document.getElementById('funnel-step-quiz')!;
  const thankYouEl = document.getElementById('funnel-step-thank-you')!;
  const root = document.getElementById('funnel-root')!;
  const announcer = document.getElementById('funnel-announcer')!;
  const progressCurrentEl = document.querySelector<HTMLElement>('[data-progress-current]');
  const progressTotalEl = document.querySelector<HTMLElement>('[data-progress-total]');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  root.dataset.step = state.step;

  function setPanelState(panel: HTMLElement, visible: boolean): void {
    panel.hidden = !visible;
    panel.setAttribute('aria-hidden', String(!visible));
    panel.toggleAttribute('inert', !visible);
  }

  /* ── Focus Management ─────────────────────── */

  function focusHeading(type: 'intro' | 'quiz' | 'lead' | 'thank-you'): void {
    requestAnimationFrame(() => {
      const selector: Record<string, string> = {
        intro: '#hero-heading',
        quiz: '#funnel-step-quiz [data-quiz-panel][data-question-state="active"] .quiz-question',
        lead: '#funnel-step-quiz [data-quiz-panel-id="lead"][data-question-state="active"] .lead-heading',
        'thank-you': '#thank-you-heading',
      };
      const heading = document.querySelector<HTMLElement>(selector[type]);
      heading?.focus();
    });
  }

  /* ── Live Region Announcements ────────────── */

  function announceStep(label: string): void {
    announcer.textContent = '';
    requestAnimationFrame(() => {
      announcer.textContent = label;
    });
  }

  /* ── Progress Indicator ──────────────────── */

  function updateProgress(currentStepNum: number): void {
    if (progressCurrentEl) {
      progressCurrentEl.textContent = String(currentStepNum);
    }

    if (progressTotalEl) {
      progressTotalEl.textContent = String(QUIZ_QUESTIONS.length + 1);
    }

    const dots = document.querySelectorAll<HTMLElement>('.progress-dot');
    dots.forEach((dot) => {
      const step = Number(dot.dataset.progressStep);
      if (step < currentStepNum) {
        dot.setAttribute('aria-current', 'false');
        dot.classList.add('progress-done');
      } else if (step === currentStepNum) {
        dot.setAttribute('aria-current', 'step');
        dot.classList.remove('progress-done');
      } else {
        dot.setAttribute('aria-current', 'false');
        dot.classList.remove('progress-done');
      }
    });
  }

  function showQuizStep(stepNum: number): void {
    updateProgress(stepNum);
  }

  function revealQuizSection(): void {
    const behavior: ScrollBehavior = prefersReducedMotion ? 'auto' : 'smooth';

    quizEl.scrollIntoView({
      behavior,
      block: 'start',
      inline: 'nearest',
    });
  }

  function hideFollowUpPanels(): void {
    setPanelState(thankYouEl, false);
  }

  function restartFunnel(): void {
    try {
      window.sessionStorage.removeItem(SUBMISSION_STORAGE_KEY);
    } catch {
      // Session storage is a resilience enhancement only.
    }

    state = initState();
    root.dataset.step = state.step;
    lastAnnouncedQuizStep = null;

    hideFollowUpPanels();

    const firstQuestion = QUIZ_QUESTIONS[0];
    if (firstQuestion) {
      window.dispatchEvent(
        new CustomEvent('funnel:render-quiz', {
          detail: {
            questionId: firstQuestion.id,
            selected: [],
            otherText: '',
            hasOther: Boolean(firstQuestion.hasOther),
            error: '',
            isFirstStep: true,
            isLastStep: false,
          },
        }),
      );
    }

    introEl.scrollIntoView({
      behavior: prefersReducedMotion ? 'auto' : 'smooth',
      block: 'start',
      inline: 'nearest',
    });
    focusHeading('intro');
    announceStep('Inicio del Mapa Inicial VIA');
  }

  function showThankYouPanel(): void {
    setPanelState(thankYouEl, true);
    thankYouEl.dataset.transitionState = prefersReducedMotion ? 'active' : 'entering';
    announceStep('Mapa Inicial VIA completado');
    focusHeading('thank-you');

    if (!prefersReducedMotion) {
      requestAnimationFrame(() => {
        thankYouEl.dataset.transitionState = 'active';
      });
    }
  }

  function hasPersistedSubmission(): boolean {
    try {
      return window.sessionStorage.getItem(SUBMISSION_STORAGE_KEY) === 'true';
    } catch {
      return false;
    }
  }

  function persistSubmission(): void {
    try {
      window.sessionStorage.setItem(SUBMISSION_STORAGE_KEY, 'true');
    } catch {
      // Session storage is a resilience enhancement only.
    }
  }

  function restoreSubmittedState(): void {
    if (!hasPersistedSubmission()) return;

    state = {
      ...initState(),
      step: 'thank-you',
    };
    root.dataset.step = state.step;
    showThankYouPanel();
  }

  function populateQuizStep(
    qId: string,
    question: (typeof QUIZ_QUESTIONS)[number],
    answer: { selected: string[]; otherText: string },
    error: string,
    stepNum: number,
  ): void {
    window.dispatchEvent(
      new CustomEvent('funnel:render-quiz', {
        detail: {
          questionId: qId,
          selected: answer.selected,
          otherText: answer.otherText,
          hasOther: question.hasOther ?? false,
          error,
          isFirstStep: stepNum === 1,
          isLastStep: stepNum === QUIZ_QUESTIONS.length,
        },
      }),
    );
  }

  /* ── Quiz Rendering ──────────────────────── */

  function renderQuizStep(scrollIntoView = false, focus = false, announce = true): void {
    const stepNum = getQuizStepNumber(state.step);
    if (!stepNum) return;

    const qId = getQuestionId(state.step);
    if (!qId) return;

    const question = QUIZ_QUESTIONS.find((q) => q.id === qId);
    if (!question) return;

    const answer = state.answers[qId] ?? { selected: [], otherText: '' };
    const error = state.errors[state.step] || '';

    hideFollowUpPanels();
    showQuizStep(stepNum);
    if (announce && lastAnnouncedQuizStep !== stepNum) {
      announceStep(`Paso ${stepNum} de ${QUIZ_QUESTIONS.length + 1}`);
      lastAnnouncedQuizStep = stepNum;
    }
    populateQuizStep(qId, question, answer, error, stepNum);

    if (focus) {
      requestAnimationFrame(() => {
        focusHeading('quiz');
      });
    }

    if (scrollIntoView) {
      requestAnimationFrame(() => {
        revealQuizSection();
      });
    }
  }

  /* ── Lead Rendering ──────────────────────── */

  function renderLeadStep(options: { announce?: boolean; focus?: boolean; scroll?: boolean } = {}): void {
    hideFollowUpPanels();
    updateProgress(QUIZ_QUESTIONS.length + 1);
    window.dispatchEvent(
      new CustomEvent('funnel:render-lead', {
        detail: {
          fullName: state.lead.fullName,
          whatsapp: state.lead.whatsapp,
          email: state.lead.email,
          consent: state.lead.consent,
          errors: state.errors,
          submitting: state.submitting,
          submitError: state.submitError,
        },
      }),
    );
    lastAnnouncedQuizStep = null;

    if (options.announce) {
      announceStep('Paso 6 de 6. Último paso, completá tus datos');
    }

    if (options.focus) {
      focusHeading('lead');
    }

    if (options.scroll) {
      revealQuizSection();
    }
  }

  function goToQuiz1(): void {
    if (state.step === 'hero') {
      state = advanceTo(state, 'quiz-1');
      root.dataset.step = state.step;
    }

    renderQuizStep(true, true);
  }

  function ensureQuizStarted(): boolean {
    if (state.step !== 'hero') return false;

    state = advanceTo(state, 'quiz-1');
    root.dataset.step = state.step;
    renderQuizStep(false, false, false);
    return true;
  }

  introEl.dataset.transitionState = 'active';
  quizEl.dataset.transitionState = 'active';
  hideFollowUpPanels();
  restoreSubmittedState();

  if (state.step !== 'thank-you') {
    renderQuizStep(false, false, false);
  }

  window.addEventListener('pageshow', () => {
    restoreSubmittedState();
  });

  /* ── Event: Hero CTA ─────────────────────── */

  window.addEventListener('funnel:advance', () => {
    if (hasPersistedSubmission()) {
      restoreSubmittedState();
      return;
    }

    goToQuiz1();
  });

  window.addEventListener('funnel:restart', () => {
    restartFunnel();
  });

  /* ── Event: Answer Selection ─────────────── */

  window.addEventListener('funnel:select-answer', ((e: CustomEvent) => {
    const { optionId } = e.detail;

    ensureQuizStarted();

    const qId = getQuestionId(state.step);
    if (!qId) return;

    const question = QUIZ_QUESTIONS.find((q) => q.id === qId);
    if (!question) return;

    state = toggleAnswer(state, qId, optionId, question);
    renderQuizStep();
  }) as EventListener);

  /* ── Event: Other Text Input ─────────────── */

  window.addEventListener('funnel:other-text', ((e: CustomEvent) => {
    const { text } = e.detail;

    ensureQuizStarted();

    const qId = getQuestionId(state.step);
    if (!qId) return;

    state = setOtherText(state, qId, text);
    renderQuizStep();
  }) as EventListener);

  /* ── Event: Continue ─────────────────────── */

  window.addEventListener('funnel:continue', () => {
    ensureQuizStarted();

    const qId = getQuestionId(state.step);
    if (!qId) return;

    const question = QUIZ_QUESTIONS.find((q) => q.id === qId);
    if (!question) return;

    const answer = state.answers[qId];
    if (!answer) return;

    // Validate
    const error = validateQuizAnswer(question, answer);
    if (error) {
      state = {
        ...state,
        errors: { ...state.errors, [state.step]: error },
      };
      renderQuizStep();
      return;
    }

    // Advance
    const next = nextStep(state.step);
    if (next) {
      state = advanceTo(state, next);
      root.dataset.step = state.step;
      if (state.step.startsWith('quiz-')) {
        renderQuizStep(false, true);
      } else if (state.step === 'lead') {
        renderLeadStep({ announce: true, focus: true, scroll: true });
      } else if (state.step === 'thank-you') {
        showThankYouPanel();
      }
    }
  });

  /* ── Event: Back ─────────────────────────── */

  window.addEventListener('funnel:back', () => {
    state = goBack(state);
    const currentStepNum = getQuizStepNumber(state.step);
    if (currentStepNum) {
      updateProgress(currentStepNum);
    }

    if (state.step === 'hero') {
      hideFollowUpPanels();
      introEl.scrollIntoView({
        behavior: prefersReducedMotion ? 'auto' : 'smooth',
        block: 'start',
        inline: 'nearest',
      });
      focusHeading('intro');
      announceStep('Inicio del Mapa Inicial VIA');
    } else if (state.step.startsWith('quiz-')) {
      renderQuizStep(false, true);
    } else if (state.step === 'lead') {
      renderLeadStep({ announce: true, focus: true, scroll: true });
    } else if (state.step === 'thank-you') {
      showThankYouPanel();
    }
  });

  /* ── Event: Lead Field Update ────────────── */

  window.addEventListener('funnel:update-lead', ((e: CustomEvent) => {
    const { field, value } = e.detail;
    state = updateLead(state, field, value);
    renderLeadStep();
  }) as EventListener);

  /* ── Event: Clear Lead Field Error ───────── */

  window.addEventListener('funnel:clear-lead-error', ((e: CustomEvent) => {
    const { field } = e.detail;
    state = {
      ...state,
      errors: { ...state.errors, [field]: '' },
    };
  }) as EventListener);

  /* ── Event: Lead Form Submit ─────────────── */

  window.addEventListener('funnel:submit-lead', async () => {
    // Validate lead fields
    const leadErrors = validateLead(state.lead);
    if (Object.keys(leadErrors).length > 0) {
      state = {
        ...state,
        errors: { ...state.errors, ...leadErrors },
      };
      renderLeadStep();
      return;
    }

    // Submit
    state = setSubmitting(state, true);
    renderLeadStep();

    const payload = buildSubmission(state);
    const result = await submitFunnel(payload);

    if (result.ok) {
      state = setSubmitting(state, false);
      state = advanceTo(state, 'thank-you');
      root.dataset.step = state.step;
      persistSubmission();
      showThankYouPanel();
    } else {
      state = setSubmitError(
        state,
        result.error ?? 'Ocurrió un error inesperado. Por favor, intentá de nuevo.',
      );
      renderLeadStep();
    }
  });
</script>

<style>
  #funnel-root {
    width: 100%;
    min-height: 100dvh;
  }

  .funnel-panel {
    width: 100%;
  }

  .funnel-panel-intro {
    display: grid;
    gap: 0;
  }

  #funnel-root [data-transition-state='active'] {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    #funnel-root [data-transition-state='active'] {
      transition: none !important;
      transform: none !important;
      will-change: auto;
    }
  }
</style>
