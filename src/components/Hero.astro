---
// Hero — Warm split hero with finalized SVG illustration.
// Cream-led background with restrained gold/night-blue accents.
// Left-aligned copy in night-blue, right-side project-owned hero art.
// CTA dispatches `funnel:advance` — functional behavior unchanged.
const whatsappMessage = 'Hola, quiero recibir orientación sobre el Método VIA. Vengo desde la web y me gustaría conversar sobre mi situación.';
const whatsappUrl = `https://wa.me/5491126967602?text=${encodeURIComponent(whatsappMessage)}`;
---

<section id="funnel-hero" class="hero gradient-hero">
  <div class="hero-grid">
    <!-- Left: text block -->
    <div class="hero-text">
      <h1 id="hero-heading" class="hero-headline" tabindex="-1">
        Descubrí qué está frenando tu crecimiento y empezá a construir una vida con mayor claridad y propósito.
      </h1>
      <p class="hero-subtitle">
        Cada persona vive una historia diferente.
      </p>
      <p class="hero-subtitle hero-subtitle-secondary">
        El Método VIA® (Visión, Integración y Acción) propone un recorrido personalizado para comprender qué está ocurriendo, ampliar la mirada y comenzar a diseñar nuevas posibilidades para tu vida.
      </p>
      <p class="hero-choice-copy">
        Podés hacer el diagnóstico para ordenar tu situación o escribirnos directamente si querés orientación ahora.
      </p>
      <div class="hero-actions" aria-label="Opciones para recibir orientación">
        <button
          id="hero-cta"
          class="btn hero-cta focus-ring-gold"
          type="button"
          aria-label="Comenzar el diagnóstico gratuito"
          aria-controls="funnel-step-quiz"
        >
          Comenzar diagnóstico gratuito
        </button>
        <a
          class="btn hero-whatsapp-cta focus-ring-cream"
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Hablar ahora por WhatsApp"
        >
          Hablar por WhatsApp
        </a>
      </div>
      <div class="hero-trust" aria-label="Beneficios del diagnóstico">
        <p>✔ Solo te llevará unos minutos.</p>
        <p>✔ Si preferís hablar primero, WhatsApp está disponible desde el inicio.</p>
      </div>
    </div>

    <!-- Right: finalized hero illustration -->
    <div class="hero-illustration" aria-hidden="true">
      <!-- Approved final hero art: project-owned SVG asset. -->
      <img
        src="/images/funnel/hero-scene.svg"
        alt=""
        class="hero-img"
        width="800"
        height="600"
        loading="eager"
      />
    </div>
  </div>
  <a
    class="mobile-whatsapp-sticky focus-ring-cream"
    href={whatsappUrl}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Hablar por WhatsApp"
  >
    WhatsApp
  </a>
</section>

<script>
  const cta = document.getElementById('hero-cta');
  cta?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('funnel:advance'));
  });
</script>

<style>
  .hero {
    display: flex;
    align-items: center;
    min-height: 100dvh;
    padding: clamp(1.5rem, 2.8vw, 2.5rem) clamp(1.25rem, 3vw, 3rem) clamp(1rem, 2vw, 1.5rem);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(380px, 0.92fr);
    align-items: center;
    gap: clamp(2rem, 4vw, 3.25rem);
    width: 100%;
    max-width: 1140px;
    margin: 0 auto;
  }

  /* ── Left: text ──────────────────────────── */
  .hero-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    max-width: 575px;
  }

  .hero-headline {
    color: var(--via-night-blue);
    margin-bottom: 0.85rem;
    letter-spacing: -0.02em;
    font-size: clamp(2.3rem, 4vw, 3.35rem);
    line-height: 1.01;
    text-wrap: balance;
    max-width: 12ch;
  }

  .hero-subtitle {
    font-size: 1rem;
    line-height: 1.62;
    margin-bottom: 0.6rem;
    color: var(--via-gray-600);
    max-width: 52ch;
  }

  .hero-subtitle-secondary {
    margin-bottom: 0.85rem;
  }

  .hero-choice-copy {
    max-width: 48ch;
    margin-bottom: 1.15rem;
    font-size: 0.98rem;
    line-height: 1.58;
    color: var(--via-night-blue);
    font-weight: var(--fw-semibold);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .hero-trust {
    display: grid;
    gap: 0.35rem;
    margin-top: 0.75rem;
    font-size: 0.92rem;
    line-height: 1.45;
    color: var(--via-gray-600);
  }

  .hero-trust p {
    margin: 0;
  }

  /* ── CTA — night-blue fill, gold hover ───── */
  .hero-cta {
    background: var(--via-night-blue);
    color: var(--via-white);
    border-color: var(--via-night-blue);
    font-size: 0.98rem;
    padding: 0.88rem 1.75rem;
    border-radius: var(--radius-md);
    box-shadow: 0 4px 14px rgba(26, 39, 68, 0.15);
  }

  .hero-cta:hover {
    background: var(--via-gold);
    color: var(--via-night-blue);
    border-color: var(--via-gold);
    box-shadow: 0 6px 20px rgba(255, 215, 0, 0.25);
  }

  .hero-cta:active {
    transform: translateY(1px);
  }

  .hero-whatsapp-cta {
    background: var(--via-white);
    color: var(--via-night-blue);
    border-color: rgba(26, 39, 68, 0.22);
    font-size: 0.98rem;
    padding: 0.88rem 1.45rem;
    border-radius: var(--radius-md);
    box-shadow: 0 4px 14px rgba(26, 39, 68, 0.08);
  }

  .hero-whatsapp-cta:hover {
    border-color: var(--via-sage-dark);
    background: rgba(183, 196, 177, 0.2);
    box-shadow: 0 6px 18px rgba(26, 39, 68, 0.1);
  }

  .mobile-whatsapp-sticky {
    display: none;
  }

  /* ── Right: illustration ─────────────────── */
  .hero-illustration {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-img {
    width: 100%;
    height: auto;
    max-width: 520px;
    border-radius: var(--via-scene-radius);
    box-shadow: var(--via-scene-shadow);
  }

  @media (min-width: 961px) {
    .hero {
      min-height: 100dvh;
      padding-top: 1.5rem;
      padding-bottom: 1.5rem;
    }

    .hero-grid {
      max-width: 1120px;
      gap: 2.6rem;
    }

    .hero-text {
      max-width: 560px;
    }

    .hero-img {
      max-width: 500px;
    }
  }

  /* ── Mobile collapse (<768px) ────────────── */
  @media (max-width: 767px) {
    .hero {
      min-height: auto;
      padding: 1.5rem 1rem 1rem;
    }

    .hero-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .hero-text {
      align-items: flex-start;
      text-align: left;
      max-width: 100%;
    }

    .hero-headline {
      font-size: clamp(1.9rem, 7vw, 2.5rem);
    }

    .hero-subtitle {
      font-size: 0.975rem;
      text-align: left;
    }

    .hero-img {
      max-width: 400px;
    }

    .hero-cta {
      width: 100%;
      max-width: 340px;
    }

    .hero-actions {
      width: 100%;
    }

    .hero-whatsapp-cta {
      width: 100%;
      max-width: 340px;
    }

    .hero-trust {
      text-align: left;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: 1.25rem 1rem 4.6rem;
    }

    .mobile-whatsapp-sticky {
      position: fixed;
      left: 1rem;
      right: 1rem;
      bottom: calc(1rem + env(safe-area-inset-bottom));
      z-index: 20;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 3.25rem;
      border-radius: 999px;
      background: var(--via-night-blue);
      color: var(--via-white);
      font-family: var(--ff-body);
      font-weight: var(--fw-semibold);
      text-decoration: none;
      box-shadow: 0 12px 28px rgba(26, 39, 68, 0.22);
    }
  }
</style>
