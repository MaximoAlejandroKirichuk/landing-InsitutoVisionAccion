---
// ThankYou — post-submission confirmation with WhatsApp CTA.
// Rendered as the final consultation panel in the funnel.
const whatsappMessage = 'Hola, quiero mi orientación personalizada. Ya completé el Mapa Inicial VIA® desde la web y me gustaría conversar sobre mi situación.';
const whatsappUrl = `https://wa.me/5491126967602?text=${encodeURIComponent(whatsappMessage)}`;
---

<section
  id="funnel-step-thank-you"
  class="thank-you surface-sage-wash"
  hidden
  aria-labelledby="thank-you-heading"
>
  <div class="thank-you-content">
    <div class="thank-you-intro">
      <div class="thank-you-illustration" aria-hidden="true">
        <img
          src="/images/funnel/thank-you-scene.svg"
          alt=""
          class="thank-you-img"
          width="600"
          height="400"
          loading="lazy"
        />
      </div>

      <div class="thank-you-copy">
        <p class="thank-you-kicker">Cuestionario completado</p>
        <h2 id="thank-you-heading" class="thank-you-heading" tabindex="-1">
          ¡Gracias por completar tu Mapa Inicial VIA®!
        </h2>

        <p class="thank-you-body">
          Tu información ya fue recibida. Ya tenemos tus respuestas del Mapa Inicial VIA® y podemos orientarte según tu momento actual.
        </p>
        <p class="thank-you-body thank-you-body-secondary">
          El próximo paso es muy simple.
        </p>
        <p class="thank-you-body thank-you-body-tertiary">
          Podés solicitar una primera orientación para conversar sobre tu situación, responder tus dudas y conocer cómo podemos acompañarte.
        </p>
        <div class="thank-you-actions">
          <a
            id="thank-you-whatsapp-link"
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn thank-you-cta focus-ring-gold"
          >
            Quiero mi orientación personalizada
          </a>
          <p class="thank-you-note">
            La orientación inicial tiene un carácter informativo y de acompañamiento. No constituye un diagnóstico ni reemplaza la atención médica, psicológica o psiquiátrica cuando esta sea necesaria.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const thankYouPanel = document.getElementById('funnel-step-thank-you');
  const thankYouWhatsappLink = document.getElementById(
    'thank-you-whatsapp-link',
  ) as HTMLAnchorElement | null;

  thankYouWhatsappLink?.addEventListener('click', (event) => {
    if (!thankYouPanel || thankYouPanel.hidden || thankYouPanel.hasAttribute('inert')) {
      return;
    }

    const href = thankYouWhatsappLink.href;
    if (!href) return;

    event.preventDefault();
    window.location.assign(href);
  });
</script>

<style>
  .thank-you {
    position: fixed;
    inset: 0;
    z-index: 80;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100dvh;
    padding: clamp(1.25rem, 3vw, 2.5rem);
    overflow: clip;
    background:
      radial-gradient(circle at top left, rgba(255, 255, 255, 0.75), transparent 42%),
      linear-gradient(135deg, rgba(252, 249, 242, 0.98) 0%, rgba(245, 240, 229, 0.98) 50%, rgba(213, 221, 209, 0.92) 100%);
    opacity: 0;
    pointer-events: none;
  }

  .thank-you[hidden] {
    display: none !important;
  }

  .thank-you[data-transition-state='entering'],
  .thank-you[data-transition-state='active'],
  .thank-you[data-transition-state='exiting'] {
    transition:
      opacity 320ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 320ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .thank-you[data-transition-state='entering'] {
    opacity: 0;
    transform: translateY(18px) scale(0.985);
  }

  .thank-you[data-transition-state='active'] {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .thank-you[data-transition-state='exiting'] {
    opacity: 0;
    transform: translateY(8px) scale(0.99);
  }

  .thank-you-content {
    width: 100%;
    max-width: 980px;
    display: grid;
    gap: 1.75rem;
  }

  .thank-you-intro {
    display: grid;
    gap: 1rem;
    align-items: center;
    text-align: center;
  }

  .thank-you-illustration {
    margin-bottom: 0;
    justify-self: center;
  }

  .thank-you-img {
    width: 100%;
    height: auto;
    max-width: min(100%, 360px);
    max-height: clamp(220px, 34vh, 320px);
    object-fit: contain;
    border-radius: var(--via-scene-radius);
    box-shadow: var(--via-scene-shadow);
    opacity: 0.92;
  }

  .thank-you-copy {
    display: grid;
    gap: 0.75rem;
  }

  .thank-you-kicker {
    margin: 0;
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: none;
    color: var(--via-rust, #b46430);
  }

  .thank-you-heading {
    font-family: inherit;
    font-size: clamp(1.75rem, 4vw, 2.4rem);
    font-weight: 600;
    line-height: 1.12;
    margin: 0;
    outline: none;
    color: var(--via-night-blue);
    max-width: 12ch;
  }

  .thank-you-body {
    font-size: 1.02rem;
    line-height: 1.62;
    color: var(--via-gray-600);
    margin: 0;
    max-width: 48ch;
  }

  .thank-you-actions {
    max-width: 420px;
    margin: 0;
    display: grid;
    gap: 0.85rem;
    justify-items: start;
  }

  .thank-you-cta {
    width: auto;
    min-width: 280px;
    font-size: 1rem;
    padding: 0.95rem 1.5rem;
    text-align: center;
    background: var(--via-night-blue);
    color: var(--via-white);
    border-color: var(--via-night-blue);
    box-shadow: 0 2px 10px rgba(26, 39, 68, 0.12);
  }

  .thank-you-cta:hover {
    background: var(--via-gold);
    color: var(--via-night-blue);
    border-color: var(--via-gold);
    box-shadow: 0 4px 16px rgba(255, 215, 0, 0.22);
  }

  .thank-you-cta:active {
    transform: translateY(1px);
  }

  .thank-you-note {
    margin: 0;
    color: var(--via-gray-600);
    font-size: 0.98rem;
    line-height: 1.5;
  }

  .thank-you-body-tertiary {
    color: var(--via-night-blue);
  }

  /* ── Reduced Motion ─────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .thank-you {
      animation: none !important;
      transition: none !important;
      transform: none !important;
    }

    .thank-you-cta {
      transition: none !important;
    }

    .thank-you-cta:active {
      transform: none;
    }
  }

  /* ── Mobile ─────────────────────────────────── */

  @media (max-width: 640px) {
    .thank-you {
      padding: 1.5rem 1rem 1.75rem;
      align-items: flex-start;
      padding-top: 2.25rem;
    }

    .thank-you-body {
      font-size: 0.98rem;
      margin: 0 auto;
    }

    .thank-you-img {
      max-width: 260px;
      max-height: 210px;
    }

    .thank-you-actions {
      margin: 0 auto;
      justify-items: center;
    }

    .thank-you-cta {
      width: 100%;
      min-width: 0;
    }

  }

  @media (min-width: 960px) {
    .thank-you-intro {
      grid-template-columns: minmax(0, 1fr) minmax(280px, 380px);
      column-gap: clamp(2rem, 4vw, 4rem);
      text-align: left;
    }

    .thank-you-illustration {
      grid-column: 2;
      grid-row: 1 / span 4;
      justify-self: end;
      align-self: center;
      max-width: 100%;
    }

    .thank-you-heading,
    .thank-you-body {
      grid-column: 1;
      justify-self: start;
    }

    .thank-you-body {
      margin-left: 0;
    }

    .thank-you-copy {
      grid-column: 1;
      justify-self: start;
      text-align: left;
    }
  }

</style>
