---
import ProgressIndicator from './ProgressIndicator.astro';
import { QUIZ_QUESTIONS } from '../lib/quizData';

const SUPPORT_MESSAGES = [
  'Elegí la opción que hoy resuene más con vos.',
  'No existen respuestas correctas.',
  'Respondé con honestidad.',
  'Tomate unos segundos antes de elegir.',
  'Elegí aquello que hoy sea más importante para vos.',
];
---

<section
  id="funnel-step-quiz"
  class="quiz-step frame-cream"
  aria-labelledby="quiz-intro-heading"
>
  <div class="quiz-shell">
    <header class="quiz-intro">
      <p class="quiz-kicker">Inicio del diagnóstico</p>
      <h2 id="quiz-intro-heading" class="quiz-intro-heading">
        Mapa Inicial VIA®
      </h2>
      <p class="quiz-intro-body">
        Respondé estas preguntas para comprender mejor el momento en el que te encontrás hoy.
      </p>
      <p class="quiz-intro-body quiz-intro-body-secondary">
        A partir de tus respuestas podremos orientarte hacia el proceso de acompañamiento que mejor se adapte a tu realidad.
      </p>
    </header>

    <div class="quiz-card">
      <div class="quiz-card-top">
        <p class="quiz-card-eyebrow">
          Pregunta <span data-quiz-step-current>1</span> de <span data-quiz-step-total>{QUIZ_QUESTIONS.length}</span>
        </p>
        <div class="quiz-progress-wrap">
          <ProgressIndicator />
        </div>
      </div>

      <div class="quiz-panels" data-quiz-panels>
        <div class="quiz-question-stage">
          {QUIZ_QUESTIONS.map((question, index) => (
            <article
              class="quiz-question-block"
              data-quiz-question
              data-quiz-question-id={question.id}
              data-quiz-question-index={index + 1}
              data-quiz-question-type={question.type}
              data-question-state={question.id === 'q1' ? 'active' : 'hidden'}
              hidden={question.id !== 'q1'}
            >
              <div class="quiz-question-layout">
                <div class="quiz-question-copy">
                  <h3 id={`quiz-question-${question.id}`} class="quiz-question" tabindex="-1">
                    {question.text}
                  </h3>
                  <p class="quiz-question-support">
                    {SUPPORT_MESSAGES[index % SUPPORT_MESSAGES.length]}
                  </p>

                  <div class="quiz-options" data-quiz-options>
                    {question.options.map((option) => (
                      <button
                        type="button"
                        class="quiz-option"
                        data-quiz-option
                        data-option-id={option.id}
                        aria-pressed="false"
                      >
                        <span class="quiz-option-copy">{option.text}</span>
                      </button>
                    ))}
                  </div>

                  {question.hasOther && (
                    <div class="quiz-other" data-quiz-other hidden>
                      <label for={`quiz-other-input-${question.id}`} class="quiz-other-label">
                        {question.otherPlaceholder || 'Contanos más...'}
                      </label>
                      <input
                        type="text"
                        id={`quiz-other-input-${question.id}`}
                        class="quiz-other-input"
                        maxlength="200"
                        aria-describedby={`quiz-error-${question.id}`}
                        data-quiz-other-input
                      />
                    </div>
                  )}

                  <div
                    id={`quiz-error-${question.id}`}
                    class="quiz-error"
                    role="alert"
                    hidden
                    data-quiz-error
                  ></div>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>

      <nav class="quiz-nav">
        <button id="quiz-btn-back" class="btn quiz-btn-back focus-ring-light" type="button" disabled>
          Atrás
        </button>
        <button
          id="quiz-btn-continue"
          class="btn quiz-btn-continue focus-ring-gold"
          type="button"
        >
          Siguiente
        </button>
      </nav>
    </div>
  </div>
</section>

<script>
  type QuizRenderData = {
    questionId?: string;
    selected: string[];
    otherText: string;
    hasOther: boolean;
    error: string;
    isFirstStep: boolean;
    isLastStep: boolean;
  };

  const container = document.getElementById('funnel-step-quiz')!;
  const panels = container.querySelector<HTMLElement>('[data-quiz-panels]')!;
  const stepCurrent = container.querySelector<HTMLElement>('[data-quiz-step-current]');
  const questionBlocks = Array.from(
    container.querySelectorAll<HTMLElement>('[data-quiz-question]'),
  );
  const btnBack = document.getElementById('quiz-btn-back') as HTMLButtonElement;
  const btnContinue = document.getElementById('quiz-btn-continue') as HTMLButtonElement;
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  let transitionTimer: number | undefined;

  function clearTransitionTimer(): void {
    if (transitionTimer !== undefined) {
      window.clearTimeout(transitionTimer);
      transitionTimer = undefined;
    }
  }

  function setQuestionState(block: HTMLElement, nextState: 'hidden' | 'entering' | 'active' | 'exiting'): void {
    block.dataset.questionState = nextState;
    block.hidden = nextState === 'hidden';
    block.setAttribute('aria-hidden', String(nextState !== 'active'));
    block.toggleAttribute('inert', nextState !== 'active');
  }

  function syncPanelHeight(activeBlock: HTMLElement): void {
    panels.style.minHeight = `${activeBlock.getBoundingClientRect().height}px`;
  }

  function render(data: QuizRenderData) {
    const activeBlock = data.questionId
      ? questionBlocks.find((block) => block.dataset.quizQuestionId === data.questionId)
      : undefined;
    const currentBlock = questionBlocks.find((block) => block.dataset.questionState === 'active');

    clearTransitionTimer();

    if (!activeBlock) return;

    if (stepCurrent) {
      const currentIndex = Number(activeBlock.dataset.quizQuestionIndex ?? '1');
      stepCurrent.textContent = String(currentIndex);
    }

    questionBlocks.forEach((block) => {
      if (block === activeBlock) return;
      if (block.hidden) return;
      if (block.dataset.questionState === 'active') {
        setQuestionState(block, 'exiting');
      }
    });

    if (currentBlock && currentBlock !== activeBlock && !currentBlock.hidden) {
      setQuestionState(currentBlock, 'exiting');
    }

    setQuestionState(activeBlock, currentBlock === activeBlock ? 'active' : 'entering');
    activeBlock.hidden = false;

    if (prefersReducedMotion || currentBlock === activeBlock) {
      setQuestionState(activeBlock, 'active');
      syncPanelHeight(activeBlock);
    } else {
      panels.style.minHeight = `${Math.max(currentBlock?.getBoundingClientRect().height ?? 0, activeBlock.getBoundingClientRect().height)}px`;
      requestAnimationFrame(() => {
        setQuestionState(activeBlock, 'active');
      });

      if (currentBlock && currentBlock !== activeBlock) {
        transitionTimer = window.setTimeout(() => {
          setQuestionState(currentBlock, 'hidden');
          syncPanelHeight(activeBlock);
        }, 240);
      }
    }

    const selectedSet = new Set(data.selected);

    activeBlock.querySelectorAll<HTMLButtonElement>('[data-quiz-option]').forEach((btn) => {
      const optionId = btn.dataset.optionId ?? '';
      const selected = selectedSet.has(optionId);
      btn.classList.toggle('selected', selected);
      btn.setAttribute('aria-pressed', String(selected));
    });

    const otherBlock = activeBlock.querySelector<HTMLElement>('[data-quiz-other]');
    const otherInput = activeBlock.querySelector<HTMLInputElement>('[data-quiz-other-input]');
    const showOther = data.hasOther && selectedSet.has('otro');

    if (otherBlock) {
      otherBlock.hidden = !showOther;
    }

    if (otherInput) {
      otherInput.value = data.otherText;
    }

    const errorEl = activeBlock.querySelector<HTMLElement>('[data-quiz-error]');
    if (errorEl) {
      errorEl.textContent = data.error;
      errorEl.hidden = !data.error;
      if (data.error) {
        btnContinue.setAttribute('aria-describedby', errorEl.id);
      } else {
        btnContinue.removeAttribute('aria-describedby');
      }
    }

    btnBack.disabled = data.isFirstStep;
    btnContinue.textContent = data.isLastStep ? 'Continuar' : 'Siguiente';

  }

  container.addEventListener('click', (event) => {
    const target = event.target as HTMLElement | null;
    const button = target?.closest<HTMLElement>('[data-quiz-option]');
    if (!button) return;

    const optionId = button.getAttribute('data-option-id');
    if (!optionId) return;

    window.dispatchEvent(new CustomEvent('funnel:select-answer', { detail: { optionId } }));
  });

  container.addEventListener('input', (event) => {
    const target = event.target as HTMLInputElement | null;
    if (!target?.matches('[data-quiz-other-input]')) return;

    window.dispatchEvent(
      new CustomEvent('funnel:other-text', { detail: { text: target.value } }),
    );
  });

  window.addEventListener('funnel:render-quiz', ((e: CustomEvent<QuizRenderData>) => {
    render(e.detail);
  }) as EventListener);

  btnContinue.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('funnel:continue'));
  });

  btnBack.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('funnel:back'));
  });
</script>

<style>
  .quiz-step {
    position: relative;
    width: min(100%, 980px);
    margin: clamp(2rem, 5vw, 3.5rem) auto 0;
    padding: 0 clamp(1rem, 3vw, 1.5rem) clamp(1.5rem, 3vw, 2rem);
    border: 0;
    background: transparent;
    box-shadow: none;
    scroll-margin-top: clamp(1rem, 4vw, 2rem);
  }

  .quiz-shell {
    display: grid;
    gap: clamp(1.4rem, 3vw, 2rem);
  }

  .quiz-intro {
    display: grid;
    justify-items: center;
    gap: 0.85rem;
    max-width: 680px;
    margin: 0 auto;
    text-align: center;
  }

  .quiz-kicker {
    margin: 0;
    font-size: 0.78rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--via-rust, #b46430);
  }

  .quiz-intro-heading {
    margin: 0;
    max-width: 13ch;
    color: var(--via-night-blue);
    font-size: clamp(1.85rem, 4.3vw, 3rem);
    line-height: 1.02;
    letter-spacing: -0.03em;
  }

  .quiz-intro-body {
    margin: 0;
    max-width: 33ch;
    color: var(--via-gray-600);
    font-size: clamp(0.98rem, 1.6vw, 1.08rem);
    line-height: 1.62;
  }

  .quiz-intro-body-secondary {
    max-width: 40ch;
  }

  .quiz-card {
    display: grid;
    gap: clamp(1.15rem, 2.4vw, 1.6rem);
    width: 100%;
    max-width: 920px;
    margin: 0 auto;
    padding: clamp(1rem, 2.2vw, 1.55rem);
    border-radius: 32px;
    border: 1px solid rgba(227, 219, 208, 0.95);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.92) 0%, rgba(251, 247, 242, 0.96) 100%);
    box-shadow:
      0 18px 40px rgba(26, 39, 68, 0.05),
      inset 0 1px 0 rgba(255, 255, 255, 0.85);
  }

  .quiz-card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .quiz-card-eyebrow {
    margin: 0;
    font-size: 0.82rem;
    font-weight: var(--fw-bold);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--via-night-blue);
  }

  .quiz-progress-wrap {
    width: 100%;
    max-width: 190px;
  }

  .quiz-progress-wrap :global(.progress) {
    justify-items: end;
    gap: 0.35rem;
    margin-bottom: 0;
    padding: 0;
    border: 0;
    background: transparent;
    box-shadow: none;
  }

  .quiz-progress-wrap :global(.progress-meta) {
    display: none;
  }

  .quiz-progress-wrap :global(.progress-track) {
    justify-content: flex-end;
    gap: 0.35rem;
  }

  .quiz-progress-wrap :global(.progress-dot) {
    width: 0.38rem;
    height: 0.38rem;
    border: 0;
    background: rgba(217, 209, 192, 0.7);
    box-shadow: none;
  }

  .quiz-progress-wrap :global(.progress-dot[aria-current='step']) {
    width: 1.55rem;
    background: #d58a34;
    box-shadow: none;
    transform: none;
  }

  .quiz-progress-wrap :global(.progress-dot.progress-done) {
    background: rgba(213, 138, 52, 0.85);
  }

  .quiz-panels {
    display: grid;
    width: 100%;
  }

  .quiz-question-stage {
    display: grid;
    grid-template-areas: 'stack';
    width: 100%;
    overflow: clip;
  }

  .quiz-question-block {
    display: block;
    grid-area: stack;
    width: 100%;
    transition:
      opacity 240ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 240ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .quiz-question-block[data-question-state='entering'] {
    opacity: 0;
    transform: translateY(14px);
  }

  .quiz-question-block[data-question-state='active'] {
    opacity: 1;
    transform: translateY(0);
    z-index: 1;
  }

  .quiz-question-block[data-question-state='exiting'] {
    opacity: 0;
    transform: translateY(-10px);
    pointer-events: none;
  }

  .quiz-question-block[hidden] {
    display: none !important;
  }

  .quiz-question-layout {
    display: block;
    width: 100%;
  }

  .quiz-question-copy {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    padding: clamp(0.15rem, 0.8vw, 0.35rem) 0;
  }

  .quiz-question {
    font-family: var(--ff-heading);
    font-size: clamp(1.55rem, 2.7vw, 2.3rem);
    text-align: center;
    margin: 0 0 0.55rem;
    max-width: 20ch;
    outline: none;
    color: var(--via-night-blue);
    line-height: 1.14;
  }

  .quiz-question-support {
    margin: 0 0 1.1rem;
    font-size: 0.92rem;
    font-style: italic;
    color: var(--via-rust, #9a5a39);
  }

  .quiz-options {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 0.75rem;
    width: 100%;
    max-width: 100%;
    margin-bottom: 0.9rem;
  }

  .quiz-option {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    width: 100%;
    gap: 1rem;
    min-height: 68px;
    padding: 0.95rem 1rem;
    font-family: var(--ff-body);
    font-size: 0.98rem;
    font-weight: var(--fw-regular);
    text-align: left;
    color: #7b4b44;
    background: rgba(255, 255, 255, 0.68);
    border: 1px solid rgba(231, 222, 213, 0.96);
    border-radius: 22px;
    box-shadow:
      0 8px 20px rgba(26, 39, 68, 0.03),
      inset 0 1px 0 rgba(255, 255, 255, 0.78);
    cursor: pointer;
    transition:
      border-color var(--transition-base),
      background var(--transition-base),
      box-shadow var(--transition-base),
      color var(--transition-base),
      transform var(--transition-base);
  }

  .quiz-option::after {
    content: '';
    flex: none;
    order: -1;
    width: 1.15rem;
    height: 1.15rem;
    border-radius: 999px;
    border: 1.5px solid rgba(219, 207, 197, 0.95);
    background: rgba(255, 255, 255, 0.96);
    box-shadow:
      inset 0 0 0 2px rgba(255, 255, 255, 0.4),
      0 1px 2px rgba(26, 39, 68, 0.04);
  }

  .quiz-option-copy {
    flex: 1;
  }

  .quiz-option:hover {
    border-color: rgba(213, 138, 52, 0.45);
    background: rgba(255, 255, 255, 0.88);
    color: #6b3d36;
    box-shadow:
      0 12px 22px rgba(26, 39, 68, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.72);
    transform: translateY(-1px);
  }

  .quiz-option:active {
    transform: translateY(1px);
  }

  .quiz-option:focus-visible {
    outline: 2.5px solid #d58a34;
    outline-offset: 2px;
    border-color: #d58a34;
  }

  .quiz-option.selected {
    border-color: rgba(213, 138, 52, 0.72);
    background: linear-gradient(180deg, rgba(255, 252, 249, 1) 0%, rgba(248, 238, 228, 0.96) 100%);
    color: var(--via-night-blue);
    box-shadow:
      0 0 0 1px rgba(213, 138, 52, 0.28),
      0 12px 24px rgba(213, 138, 52, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.82);
  }

  .quiz-option.selected:hover {
    border-color: #d58a34;
    background: linear-gradient(180deg, rgba(255, 252, 249, 1) 0%, rgba(247, 234, 221, 1) 100%);
  }

  .quiz-option.selected:focus-visible {
    outline-color: #d58a34;
  }

  .quiz-option.selected::after {
    border-color: #d58a34;
    background: #d58a34;
    box-shadow: 0 0 0 4px rgba(213, 138, 52, 0.12);
  }

  .quiz-other {
    width: 100%;
    max-width: 100%;
    margin-bottom: 1rem;
  }

  .quiz-other-label {
    display: block;
    font-size: 0.875rem;
    font-weight: var(--fw-semibold);
    color: #7b4b44;
    margin-bottom: 0.5rem;
  }

  .quiz-other-input {
    width: 100%;
    padding: 0.78rem 0.95rem;
    font-family: var(--ff-body);
    font-size: 1rem;
    color: var(--via-gray-800);
    background: rgba(255, 255, 255, 0.96);
    border: 1.5px solid var(--via-gray-300);
    border-radius: var(--radius-md);
    transition: border-color var(--transition-base),
                box-shadow var(--transition-base);
  }

  .quiz-other-input:focus {
    border-color: #d58a34;
    outline: none;
    box-shadow: 0 0 0 4px rgba(213, 138, 52, 0.14);
  }

  .quiz-other-input::placeholder {
    color: var(--via-gray-400);
  }

  .quiz-error {
    width: 100%;
    max-width: 100%;
    padding: 0.8rem 0.95rem;
    margin-bottom: 0.25rem;
    font-size: 0.875rem;
    font-weight: var(--fw-semibold);
    color: var(--via-night-blue);
    background: rgba(230, 194, 0, 0.12);
    border: 1px solid var(--via-gold);
    border-radius: var(--radius-sm);
  }

  .quiz-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.65rem;
    width: 100%;
    max-width: 100%;
  }

  .quiz-nav .quiz-btn-continue {
    flex: 0 0 auto;
    min-width: 168px;
  }

  .quiz-nav .quiz-btn-back {
    flex: 0 0 auto;
    min-width: 92px;
  }

  .quiz-btn-back {
    background: transparent;
    color: rgba(123, 98, 90, 0.72);
    border-color: transparent;
    box-shadow: none;
    padding-left: 0;
  }

  .quiz-btn-back:hover {
    background: transparent;
    border-color: transparent;
    color: var(--via-night-blue);
  }

  .quiz-btn-back:active {
    transform: translateY(1px);
  }

  .quiz-btn-back:disabled {
    opacity: 0.5;
    cursor: default;
    border-color: transparent;
    color: rgba(123, 98, 90, 0.42);
    background: transparent;
    box-shadow: none;
  }

  .quiz-btn-continue {
    background: rgba(240, 229, 229, 0.95);
    color: rgba(117, 91, 83, 0.88);
    border-color: rgba(234, 223, 223, 0.98);
    box-shadow: none;
  }

  .quiz-btn-continue:hover {
    background: rgba(231, 214, 214, 0.98);
    color: var(--via-night-blue);
    border-color: rgba(226, 211, 211, 1);
    box-shadow: none;
  }

  .quiz-btn-continue:active {
    transform: translateY(1px);
  }

  @media (prefers-reduced-motion: reduce) {
    .quiz-question-block {
      animation: none !important;
      transition: none !important;
    }

    .quiz-option,
    .quiz-option.selected,
    .quiz-other-input,
    .quiz-step * {
      transition: none !important;
    }

    .quiz-option:active,
    .quiz-btn-continue:active,
    .quiz-btn-back:active {
      transform: none;
    }
  }

  @media (max-width: 640px) {
    .quiz-step {
      margin-top: 2rem;
      padding-inline: 0.85rem;
    }

    .quiz-intro {
      justify-items: start;
      text-align: left;
    }

    .quiz-intro-heading,
    .quiz-intro-body,
    .quiz-question {
      max-width: 100%;
      text-align: left;
    }

    .quiz-card {
      padding: 1rem;
      border-radius: 24px;
    }

    .quiz-card-top {
      flex-direction: column;
      align-items: flex-start;
    }

    .quiz-progress-wrap {
      max-width: none;
      width: 100%;
    }

    .quiz-progress-wrap :global(.progress),
    .quiz-progress-wrap :global(.progress-track) {
      justify-items: start;
      justify-content: flex-start;
    }

    .quiz-question {
      font-size: 1.7rem;
    }

    .quiz-option {
      min-height: 76px;
      padding: 1rem;
      font-size: 0.98rem;
    }

    .quiz-nav {
      margin-top: 0.15rem;
    }

    .quiz-nav .quiz-btn-back,
    .quiz-nav .quiz-btn-continue {
      min-width: 0;
    }
  }

  @media (min-width: 961px) {
    .quiz-card {
      max-width: 860px;
      padding: 1rem 1.1rem 1.2rem;
    }

    .quiz-card-top {
      margin-bottom: 0.15rem;
    }

    .quiz-question-copy {
      max-width: 760px;
      margin: 0 auto;
    }

    .quiz-option {
      min-height: 64px;
      padding: 0.9rem 1rem;
    }
  }

  @media (max-width: 480px) {
    .quiz-nav {
      flex-wrap: wrap;
    }

    .quiz-nav .quiz-btn-continue {
      width: 100%;
    }
  }

</style>
