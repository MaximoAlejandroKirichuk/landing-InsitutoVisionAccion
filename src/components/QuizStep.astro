---
import ProgressIndicator from './ProgressIndicator.astro';
import { QUIZ_QUESTIONS } from '../lib/quizData';
---

<section
  id="funnel-step-quiz"
  class="quiz-step frame-cream"
  aria-label="Preguntas del test"
  hidden
>
  <ProgressIndicator />

  <div class="quiz-panels" data-quiz-panels>
    {QUIZ_QUESTIONS.map((question, index) => (
        <article
          class="quiz-question-block"
          data-quiz-question
          data-quiz-question-id={question.id}
          data-quiz-question-type={question.type}
          hidden={question.id !== 'q1'}
        >
          <div class="quiz-question-layout">
            <div class="quiz-question-copy">
              <h2 id={`quiz-question-${question.id}`} class="quiz-question" tabindex="-1">
                {question.text}
              </h2>

              <div class="quiz-options" data-quiz-options>
                {question.options.map((option) => (
                  <button
                    type="button"
                    class="quiz-option"
                    data-quiz-option
                    data-option-id={option.id}
                    aria-pressed="false"
                  >
                    {option.text}
                  </button>
                ))}
              </div>

              {question.hasOther && (
                <div class="quiz-other" data-quiz-other hidden>
                  <label for={`quiz-other-input-${question.id}`} class="quiz-other-label">
                    {question.otherPlaceholder || 'Contanos más…'}
                  </label>
                  <input
                    type="text"
                    id={`quiz-other-input-${question.id}`}
                    class="quiz-other-input"
                    maxlength="200"
                    aria-describedby={`quiz-error-${question.id}`}
                    data-quiz-other-input
                  />
                </div>
              )}

              <div
                id={`quiz-error-${question.id}`}
                class="quiz-error"
                role="alert"
                hidden
                data-quiz-error
              ></div>
            </div>

            <aside class={`quiz-visual-card visual-${question.id}`} aria-hidden="true">
              <span class="quiz-step-badge">{String(index + 1).padStart(2, '0')}</span>
              <div class={`quiz-vignette vignette-${question.id}`}></div>
            </aside>
          </div>
      </article>
    ))}
  </div>

  <nav class="quiz-nav">
    <button id="quiz-btn-back" class="btn quiz-btn-back focus-ring-light" type="button" hidden>
      Volver
    </button>
    <button
      id="quiz-btn-continue"
      class="btn quiz-btn-continue focus-ring-gold"
      type="button"
    >
      Continuar
    </button>
  </nav>
</section>

<script>
  type QuizRenderData = {
    questionId?: string;
    selected: string[];
    otherText: string;
    hasOther: boolean;
    error: string;
    isFirstStep: boolean;
    isLastStep: boolean;
  };

  const container = document.getElementById('funnel-step-quiz')!;
  const questionBlocks = Array.from(
    container.querySelectorAll<HTMLElement>('[data-quiz-question]'),
  );
  const btnBack = document.getElementById('quiz-btn-back')!;
  const btnContinue = document.getElementById('quiz-btn-continue')!;

  function render(data: QuizRenderData) {
    const activeBlock = data.questionId
      ? questionBlocks.find((block) => block.dataset.quizQuestionId === data.questionId)
      : undefined;

    questionBlocks.forEach((block) => {
      block.hidden = block !== activeBlock;
    });

    if (!activeBlock) return;

    const selectedSet = new Set(data.selected);

    activeBlock.querySelectorAll<HTMLButtonElement>('[data-quiz-option]').forEach((btn) => {
      const optionId = btn.dataset.optionId ?? '';
      const selected = selectedSet.has(optionId);
      btn.classList.toggle('selected', selected);
      btn.setAttribute('aria-pressed', String(selected));
    });

    const otherBlock = activeBlock.querySelector<HTMLElement>('[data-quiz-other]');
    const otherInput = activeBlock.querySelector<HTMLInputElement>('[data-quiz-other-input]');
    const showOther = data.hasOther && selectedSet.has('otro');

    if (otherBlock) {
      otherBlock.hidden = !showOther;
    }

    if (otherInput) {
      otherInput.value = data.otherText;
    }

    const errorEl = activeBlock.querySelector<HTMLElement>('[data-quiz-error]');
    if (errorEl) {
      errorEl.textContent = data.error;
      errorEl.hidden = !data.error;
      if (data.error) {
        btnContinue.setAttribute('aria-describedby', errorEl.id);
      } else {
        btnContinue.removeAttribute('aria-describedby');
      }
    }

    btnBack.hidden = data.isFirstStep;
    btnContinue.textContent = 'Continuar';

  }

  container.addEventListener('click', (event) => {
    const target = event.target as HTMLElement | null;
    const button = target?.closest<HTMLElement>('[data-quiz-option]');
    if (!button) return;

    const optionId = button.getAttribute('data-option-id');
    if (!optionId) return;

    window.dispatchEvent(new CustomEvent('funnel:select-answer', { detail: { optionId } }));
  });

  container.addEventListener('input', (event) => {
    const target = event.target as HTMLInputElement | null;
    if (!target?.matches('[data-quiz-other-input]')) return;

    window.dispatchEvent(
      new CustomEvent('funnel:other-text', { detail: { text: target.value } }),
    );
  });

  window.addEventListener('funnel:render-quiz', ((e: CustomEvent<QuizRenderData>) => {
    container.hidden = false;
    render(e.detail);
  }) as EventListener);

  btnContinue.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('funnel:continue'));
  });

  btnBack.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('funnel:back'));
  });
</script>

<style>
  .quiz-step {
    position: relative;
    overflow: hidden;
    width: min(100%, 1080px);
    margin: clamp(0.85rem, 2.5vw, 1.5rem) auto 0;
    padding: clamp(1.15rem, 2.2vw, 2rem);
    border-radius: calc(var(--radius-lg) + 4px);
    border: 1px solid rgba(217, 209, 192, 0.86);
    background:
      radial-gradient(ellipse 70% 42% at 12% 0%, rgba(255, 215, 0, 0.08) 0%, transparent 65%),
      radial-gradient(ellipse 60% 40% at 88% 8%, rgba(183, 196, 177, 0.14) 0%, transparent 60%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(252, 249, 242, 0.99) 100%);
    box-shadow:
      0 20px 50px rgba(26, 39, 68, 0.07),
      inset 0 1px 0 rgba(255, 255, 255, 0.8);
    scroll-margin-top: clamp(1rem, 4vw, 2rem);
  }

  .quiz-step::before,
  .quiz-step::after {
    content: '';
    position: absolute;
    pointer-events: none;
    border-radius: 999px;
    filter: blur(10px);
  }

  .quiz-step::before {
    top: -40px;
    right: -30px;
    width: 160px;
    height: 160px;
    background: rgba(255, 215, 0, 0.12);
  }

  .quiz-step::after {
    left: -20px;
    bottom: -24px;
    width: 120px;
    height: 120px;
    background: rgba(183, 196, 177, 0.12);
  }

  .quiz-panels {
    display: grid;
    width: 100%;
    gap: 1rem;
  }

  .quiz-question-block {
    display: block;
    width: 100%;
  }

  .quiz-question-block[hidden] {
    display: none !important;
  }

  .quiz-question-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 0.9rem;
    width: 100%;
  }

  .quiz-question-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    width: 100%;
    padding: clamp(1rem, 1.9vw, 1.35rem);
    border: 1px solid rgba(217, 209, 192, 0.8);
    border-radius: 24px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(250, 247, 240, 0.94) 100%);
    box-shadow:
      0 10px 28px rgba(26, 39, 68, 0.04),
      inset 0 1px 0 rgba(255, 255, 255, 0.7);
  }

  .quiz-visual-card {
    display: grid;
    place-items: center;
    gap: 1rem;
    min-height: 208px;
    padding: 1.1rem;
    border-radius: 24px;
    border: 1px solid rgba(217, 209, 192, 0.78);
    background:
      radial-gradient(circle at 50% 28%, rgba(255, 255, 255, 0.7) 0%, rgba(255, 255, 255, 0.08) 38%, transparent 68%),
      linear-gradient(180deg, rgba(245, 240, 229, 0.72) 0%, rgba(255, 255, 255, 0.9) 100%);
    box-shadow:
      0 12px 30px rgba(26, 39, 68, 0.05),
      inset 0 1px 0 rgba(255, 255, 255, 0.68);
  }

  .quiz-step-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 3.25rem;
    padding: 0.5rem 0.8rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: var(--fw-bold);
    letter-spacing: 0.14em;
    color: var(--via-night-blue);
    background: rgba(255, 255, 255, 0.76);
    border: 1px solid rgba(217, 209, 192, 0.9);
    box-shadow: 0 6px 16px rgba(26, 39, 68, 0.04);
  }

  .quiz-vignette {
    display: flex;
    align-items: center;
    justify-content: center;
    width: clamp(104px, 11vw, 156px);
    aspect-ratio: 1;
    border-radius: 50%;
    position: relative;
    background: radial-gradient(
      circle at 40% 35%,
      var(--via-cream) 0%,
      var(--via-sage-light) 50%,
      var(--via-cream-deep) 100%
    );
    box-shadow:
      0 0 40px rgba(183, 196, 177, 0.2),
      0 0 80px rgba(183, 196, 177, 0.08);
  }

  .quiz-vignette::after {
    content: '';
    position: absolute;
    inset: 11px;
    border-radius: 50%;
    border: 1.5px solid rgba(255, 215, 0, 0.2);
  }

  .vignette-q1 {
    background: radial-gradient(
      circle at 60% 40%,
      var(--via-cream) 0%,
      var(--via-sage-light) 45%,
      var(--via-cream-deep) 100%
    );
  }

  .vignette-q2 {
    background: radial-gradient(
      circle at 35% 35%,
      var(--via-cream) 0%,
      var(--via-cream-deep) 50%,
      var(--via-sage-light) 100%
    );
  }

  .vignette-q3 {
    background: radial-gradient(
      circle at 50% 30%,
      var(--via-cream) 0%,
      var(--via-sage-light) 60%,
      var(--via-cream-deep) 100%
    );
    box-shadow:
      0 0 36px rgba(183, 196, 177, 0.25),
      0 0 72px rgba(255, 215, 0, 0.06);
  }

  .vignette-q4 {
    background: radial-gradient(
      circle at 45% 50%,
      var(--via-cream) 0%,
      var(--via-cream-deep) 40%,
      var(--via-sage-light) 100%
    );
  }

  .vignette-q5 {
    background: radial-gradient(
      circle at 55% 35%,
      var(--via-cream) 0%,
      var(--via-sage-light) 50%,
      var(--via-cream-deep) 100%
    );
    box-shadow:
      0 0 44px rgba(183, 196, 177, 0.18),
      0 0 88px rgba(255, 215, 0, 0.07);
  }

  .quiz-question {
    font-family: var(--ff-heading);
    font-size: clamp(1.5rem, 2.6vw, 2.2rem);
    text-align: left;
    margin-bottom: 0.9rem;
    max-width: 18ch;
    outline: none;
    color: var(--via-night-blue);
    line-height: 1.15;
  }

  .quiz-options {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 0.72rem;
    width: 100%;
    max-width: 100%;
    margin-bottom: 1rem;
  }

  .quiz-option {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    gap: 1rem;
    min-height: 60px;
    padding: 0.95rem 1rem 0.95rem 1.1rem;
    font-family: var(--ff-body);
    font-size: 1rem;
    font-weight: var(--fw-semibold);
    text-align: left;
    color: var(--via-gray-700);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.99) 0%, rgba(252, 249, 242, 0.92) 100%);
    border: 1px solid rgba(217, 209, 192, 0.96);
    border-radius: 18px;
    box-shadow:
      0 6px 16px rgba(26, 39, 68, 0.04),
      inset 0 1px 0 rgba(255, 255, 255, 0.7);
    cursor: pointer;
    transition:
      border-color var(--transition-base),
      background var(--transition-base),
      box-shadow var(--transition-base),
      color var(--transition-base),
      transform var(--transition-base);
  }

  .quiz-option::after {
    content: '';
    flex: none;
    width: 1rem;
    height: 1rem;
    border-radius: 999px;
    border: 1.5px solid var(--via-gray-300);
    background: rgba(255, 255, 255, 0.92);
    box-shadow:
      inset 0 0 0 2px rgba(255, 255, 255, 0.4),
      0 1px 2px rgba(26, 39, 68, 0.04);
  }

  .quiz-option:hover {
    border-color: var(--via-sage);
    background: linear-gradient(180deg, rgba(252, 249, 242, 1) 0%, rgba(213, 221, 209, 0.5) 100%);
    color: var(--via-gray-800);
    box-shadow:
      0 10px 22px rgba(26, 39, 68, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.65);
    transform: translateY(-1px);
  }

  .quiz-option:active {
    transform: translateY(1px);
  }

  .quiz-option:focus-visible {
    outline: 2.5px solid var(--via-night-blue);
    outline-offset: 2px;
    border-color: var(--via-night-blue);
  }

  .quiz-option.selected {
    border-color: var(--via-gold);
    background: linear-gradient(135deg, rgba(252, 249, 242, 1) 0%, rgba(213, 221, 209, 0.72) 100%);
    color: var(--via-night-blue);
    box-shadow:
      0 0 0 1px rgba(255, 215, 0, 0.5),
      0 12px 24px rgba(255, 215, 0, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.82);
  }

  .quiz-option.selected:hover {
    border-color: var(--via-gold-deep);
    background: linear-gradient(135deg, rgba(245, 240, 229, 1) 0%, rgba(213, 221, 209, 0.9) 100%);
  }

  .quiz-option.selected:focus-visible {
    outline-color: var(--via-gold);
  }

  .quiz-option.selected::after {
    border-color: var(--via-gold);
    background: var(--via-gold);
    box-shadow: 0 0 0 4px rgba(255, 215, 0, 0.12);
  }

  .quiz-other {
    width: 100%;
    max-width: 100%;
    margin-bottom: 1rem;
  }

  .quiz-other-label {
    display: block;
    font-size: 0.875rem;
    font-weight: var(--fw-semibold);
    color: var(--via-gray-600);
    margin-bottom: 0.5rem;
  }

  .quiz-other-input {
    width: 100%;
    padding: 0.78rem 0.95rem;
    font-family: var(--ff-body);
    font-size: 1rem;
    color: var(--via-gray-800);
    background: rgba(255, 255, 255, 0.96);
    border: 1.5px solid var(--via-gray-300);
    border-radius: var(--radius-md);
    transition: border-color var(--transition-base),
                box-shadow var(--transition-base);
  }

  .quiz-other-input:focus {
    border-color: var(--via-gold);
    outline: none;
    box-shadow: 0 0 0 4px rgba(255, 215, 0, 0.14);
  }

  .quiz-other-input::placeholder {
    color: var(--via-gray-400);
  }

  .quiz-error {
    width: 100%;
    max-width: 100%;
    padding: 0.8rem 0.95rem;
    margin-bottom: 0.25rem;
    font-size: 0.875rem;
    font-weight: var(--fw-semibold);
    color: var(--via-night-blue);
    background: rgba(230, 194, 0, 0.12);
    border: 1px solid var(--via-gold);
    border-radius: var(--radius-sm);
  }

  .quiz-nav {
    display: flex;
    gap: 0.65rem;
    width: 100%;
    max-width: 100%;
    justify-content: flex-end;
  }

  .quiz-nav .quiz-btn-continue {
    flex: 1;
    min-width: 170px;
  }

  .quiz-nav .quiz-btn-back {
    flex: 0 0 160px;
    min-width: 150px;
  }

  .quiz-btn-back {
    background: transparent;
    color: var(--via-night-blue);
    border-color: var(--via-gray-300);
  }

  .quiz-btn-back:hover {
    background: var(--via-cream-deep);
    border-color: var(--via-sage);
    color: var(--via-night-blue);
  }

  .quiz-btn-back:active {
    transform: translateY(1px);
  }

  .quiz-btn-continue {
    background: var(--via-night-blue);
    color: var(--via-white);
    border-color: var(--via-night-blue);
    box-shadow: 0 6px 16px rgba(26, 39, 68, 0.12);
  }

  .quiz-btn-continue:hover {
    background: var(--via-gold);
    color: var(--via-night-blue);
    border-color: var(--via-gold);
    box-shadow: 0 4px 16px rgba(255, 215, 0, 0.22);
  }

  .quiz-btn-continue:active {
    transform: translateY(1px);
  }

  @media (prefers-reduced-motion: reduce) {
    .quiz-option,
    .quiz-option.selected,
    .quiz-other-input,
    .quiz-step * {
      transition: none !important;
    }

    .quiz-option:active,
    .quiz-btn-continue:active,
    .quiz-btn-back:active {
      transform: none;
    }
  }

  @media (max-width: 640px) {
    .quiz-step {
      padding: 0.95rem 0.85rem 1rem;
      margin-top: 1rem;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.99) 0%, rgba(251, 248, 241, 0.98) 100%);
      box-shadow:
        0 12px 28px rgba(26, 39, 68, 0.05),
        inset 0 1px 0 rgba(255, 255, 255, 0.82);
    }

    .quiz-step::before,
    .quiz-step::after {
      display: none;
    }

    .quiz-panels {
      gap: 0.9rem;
    }

    .quiz-question-layout {
      gap: 0.75rem;
    }

    .quiz-question-copy,
    .quiz-visual-card {
      border-radius: 20px;
    }

    .quiz-visual-card {
      display: none;
    }

    .quiz-question-copy {
      padding: 0.95rem;
    }

    .quiz-question {
      font-size: 1.16rem;
      max-width: 17ch;
    }

    .quiz-option {
      min-height: 52px;
      padding: 0.85rem 0.9rem;
      font-size: 0.98rem;
    }

    .quiz-nav {
      flex-direction: column;
      gap: 0.6rem;
      margin-top: 0.1rem;
    }

    .quiz-nav .quiz-btn-back,
    .quiz-nav .quiz-btn-continue {
      flex: 1 1 auto;
      min-width: 0;
      width: 100%;
    }

    .quiz-btn-back {
      order: 1;
    }

    .quiz-btn-continue {
      order: 2;
    }
  }

  @media (max-width: 480px) {
    .quiz-step {
      padding-top: 0.9rem;
    }
  }

  @media (min-width: 960px) {
    .quiz-question-layout {
      grid-template-columns: minmax(0, 1.2fr) minmax(230px, 310px);
      gap: 1.1rem;
      align-items: stretch;
    }

    .quiz-question-copy {
      padding: clamp(1.25rem, 2.1vw, 1.65rem);
    }

    .quiz-visual-card {
      min-height: 100%;
      align-content: center;
    }

    .quiz-options {
      margin-bottom: 1rem;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .quiz-question {
      max-width: 15ch;
      margin-bottom: 1rem;
    }

    .quiz-nav {
      margin-top: 0.25rem;
    }
  }
</style>
