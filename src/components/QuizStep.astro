---
import ProgressIndicator from './ProgressIndicator.astro';
import { QUIZ_QUESTIONS } from '../lib/quizData';

const whatsappMessage = 'Hola, quiero recibir orientación sobre el Método VIA. Vengo desde la web y me gustaría conversar sobre mi situación.';
const whatsappUrl = `https://wa.me/5491126967602?text=${encodeURIComponent(whatsappMessage)}`;
---

<section
  id="funnel-step-quiz"
  class="quiz-step frame-cream"
  aria-labelledby="quiz-intro-heading"
>
  <div class="quiz-shell">
    <header class="quiz-intro">
      <p class="quiz-kicker">Primer encuentro de orientación</p>
      <h2 id="quiz-intro-heading" class="quiz-intro-heading">
        Mapa Inicial VIA®
      </h2>
      <p class="quiz-intro-body">
        Conocer dónde estás hoy es el primer paso para decidir hacia dónde querés ir.
      </p>
      <p class="quiz-intro-body quiz-intro-body-secondary">
        Respondé estas preguntas. Solo te llevará unos minutos. A partir de tus respuestas podremos ofrecerte una orientación inicial sobre el proceso de acompañamiento que mejor se adapte a tu momento actual.
      </p>
      <p class="quiz-intro-body quiz-intro-body-tertiary">
        Si preferís conversar primero, escribinos por WhatsApp. Estamos para orientarte.
      </p>
    </header>

    <div class="quiz-card">
      <div class="quiz-card-top">
        <p class="quiz-card-eyebrow">
          Paso <span data-quiz-step-current>1</span> de <span data-quiz-step-total>{QUIZ_QUESTIONS.length + 1}</span>
        </p>
        <div class="quiz-progress-wrap">
          <ProgressIndicator />
        </div>
      </div>

      <div class="quiz-panels" data-quiz-panels>
        <div class="quiz-question-stage">
          {QUIZ_QUESTIONS.map((question, index) => (
            <article
              class="quiz-panel"
              data-quiz-panel
              data-quiz-panel-id={question.id}
              data-quiz-question-index={index + 1}
              data-question-state={question.id === 'q1' ? 'active' : 'hidden'}
              hidden={question.id !== 'q1'}
            >
              <div class="quiz-question-copy">
                <h3 id={`quiz-question-${question.id}`} class="quiz-question" tabindex="-1">
                  {question.text}
                </h3>
                <p class="quiz-question-support">{question.supportText}</p>

                <div class="quiz-options">
                  {question.options.map((option) => (
                    <button
                      type="button"
                      class="quiz-option"
                      data-quiz-option
                      data-option-id={option.id}
                      data-question-id={question.id}
                      aria-pressed="false"
                    >
                      <span class="quiz-option-copy">{option.text}</span>
                    </button>
                  ))}
                </div>

                {question.hasOther && (
                  <div class="quiz-other" data-quiz-other hidden>
                    <label for={`quiz-other-input-${question.id}`} class="quiz-other-label">
                      {question.otherPlaceholder || 'Contanos más...'}
                    </label>
                    <input
                      type="text"
                      id={`quiz-other-input-${question.id}`}
                      class="quiz-other-input"
                      maxlength="200"
                      aria-describedby={`quiz-error-${question.id}`}
                      data-quiz-other-input
                      data-question-id={question.id}
                    />
                  </div>
                )}

                <div
                  id={`quiz-error-${question.id}`}
                  class="quiz-error"
                  role="alert"
                  hidden
                  data-quiz-error
                ></div>
              </div>
            </article>
          ))}

          <article
            class="quiz-panel quiz-panel-lead"
            data-quiz-panel
            data-quiz-panel-id="lead"
            data-quiz-question-index={QUIZ_QUESTIONS.length + 1}
            data-question-state="hidden"
            hidden
            aria-hidden="true"
            inert
          >
            <div class="quiz-question-copy quiz-question-copy-lead">
              <div class="lead-frame">
                <p class="lead-kicker">Último paso</p>
                <h3 class="lead-heading" tabindex="-1">
                  Completá tus datos para recibir tu orientación.
                </h3>

                <p class="lead-explain">
                  Ya terminaste el cuestionario. Ahora completá este último paso para que podamos contactarte y orientarte según tu Mapa Inicial VIA®.
                </p>

                <p class="lead-explain lead-explain-secondary">
                  Si preferís conversar primero, también podés seguir por WhatsApp.
                </p>

                <form id="lead-form-inline" class="lead-form" novalidate>
                  <div class="form-field">
                    <label for="lead-fullname-inline" class="form-label">Nombre y apellido</label>
                    <input
                      type="text"
                      id="lead-fullname-inline"
                      class="form-input"
                      autocomplete="name"
                      required
                      aria-describedby="lead-error-fullname-inline"
                    />
                    <span id="lead-error-fullname-inline" class="form-error" role="alert" hidden></span>
                  </div>

                  <div class="form-field">
                    <label for="lead-whatsapp-inline" class="form-label">WhatsApp</label>
                    <input
                      type="tel"
                      id="lead-whatsapp-inline"
                      class="form-input"
                      inputmode="tel"
                      autocomplete="tel"
                      required
                      aria-describedby="lead-error-whatsapp-inline"
                    />
                    <span id="lead-error-whatsapp-inline" class="form-error" role="alert" hidden></span>
                  </div>

                  <div class="form-field">
                    <label for="lead-email-inline" class="form-label">
                      Correo electrónico <span class="form-label-optional">(opcional)</span>
                    </label>
                    <input
                      type="email"
                      id="lead-email-inline"
                      class="form-input"
                      autocomplete="email"
                      aria-describedby="lead-error-email-inline"
                    />
                    <span id="lead-error-email-inline" class="form-error" role="alert" hidden></span>
                  </div>

                  <div class="form-field">
                    <label class="form-checkbox-label">
                      <input
                        type="checkbox"
                        id="lead-consent-inline"
                        class="form-checkbox focus-ring-cream"
                        aria-describedby="lead-error-consent-inline"
                      />
                      <span class="form-checkbox-text">
                        Acepto que Instituto Visión en Acción se contacte conmigo por WhatsApp, llamada o correo electrónico en relación con mi consulta, y autorizo el tratamiento de mis datos personales para brindarme información y una orientación personalizada.
                      </span>
                    </label>
                    <span id="lead-error-consent-inline" class="form-error" role="alert" hidden></span>
                  </div>

                  <div id="lead-submit-error-inline" class="form-error form-error-submit" role="alert" hidden></div>

                  <div class="lead-actions">
                    <button
                      id="lead-btn-submit-inline"
                      class="btn lead-submit-btn focus-ring-gold"
                      type="submit"
                    >
                      Finalizar y recibir orientación
                    </button>

                    <a
                      class="btn lead-whatsapp-btn focus-ring-cream"
                      href={whatsappUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      Prefiero seguir por WhatsApp
                    </a>
                  </div>

                  <p class="lead-confidentiality">
                    ✔ Tu información será tratada con absoluta confidencialidad.
                  </p>
                </form>
              </div>
            </div>
          </article>
        </div>

        <nav class="quiz-nav">
          <button id="quiz-btn-back" class="btn quiz-btn-back focus-ring-light" type="button" disabled>
            Atrás
          </button>
          <button
            id="quiz-btn-continue"
            class="btn quiz-btn-continue focus-ring-gold"
            type="button"
          >
            Siguiente
          </button>
        </nav>
      </div>
    </div>
  </div>
</section>

<script>
  type QuizRenderData = {
    questionId?: string;
    selected: string[];
    otherText: string;
    hasOther: boolean;
    error: string;
    isFirstStep: boolean;
    isLastStep: boolean;
  };

  type LeadRenderData = {
    fullName: string;
    whatsapp: string;
    email: string;
    consent: boolean;
    errors: Record<string, string>;
    submitting: boolean;
    submitError: string;
  };

  const container = document.getElementById('funnel-step-quiz')!;
  const panels = container.querySelector<HTMLElement>('[data-quiz-panels]')!;
  const stepCurrent = container.querySelector<HTMLElement>('[data-quiz-step-current]');
  const stepTotal = container.querySelector<HTMLElement>('[data-quiz-step-total]');
  const allPanels = Array.from(container.querySelectorAll<HTMLElement>('[data-quiz-panel]'));
  const quizPanels = allPanels.filter((panel) => panel.dataset.quizPanelId !== 'lead');
  const leadPanel = container.querySelector<HTMLElement>('[data-quiz-panel-id="lead"]')!;
  const btnBack = document.getElementById('quiz-btn-back') as HTMLButtonElement;
  const btnContinue = document.getElementById('quiz-btn-continue') as HTMLButtonElement;
  const nav = container.querySelector<HTMLElement>('.quiz-nav')!;
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const leadForm = document.getElementById('lead-form-inline') as HTMLFormElement;
  const inputFullName = document.getElementById('lead-fullname-inline') as HTMLInputElement;
  const inputWhatsapp = document.getElementById('lead-whatsapp-inline') as HTMLInputElement;
  const inputEmail = document.getElementById('lead-email-inline') as HTMLInputElement;
  const inputConsent = document.getElementById('lead-consent-inline') as HTMLInputElement;
  const btnSubmit = document.getElementById('lead-btn-submit-inline') as HTMLButtonElement;
  const errorFullName = document.getElementById('lead-error-fullname-inline')!;
  const errorWhatsapp = document.getElementById('lead-error-whatsapp-inline')!;
  const errorEmail = document.getElementById('lead-error-email-inline')!;
  const errorConsent = document.getElementById('lead-error-consent-inline')!;
  const submitErrorEl = document.getElementById('lead-submit-error-inline')!;

  let transitionTimer: number | undefined;

  function clearTransitionTimer(): void {
    if (transitionTimer !== undefined) {
      window.clearTimeout(transitionTimer);
      transitionTimer = undefined;
    }
  }

  function setPanelState(panel: HTMLElement, nextState: 'hidden' | 'entering' | 'active' | 'exiting'): void {
    panel.dataset.questionState = nextState;
    panel.hidden = nextState === 'hidden';
    panel.setAttribute('aria-hidden', String(nextState !== 'active'));
    panel.toggleAttribute('inert', nextState !== 'active');
  }

  function syncPanelHeight(activePanel: HTMLElement): void {
    panels.style.minHeight = `${activePanel.getBoundingClientRect().height}px`;
  }

  function activatePanel(nextPanel: HTMLElement): void {
    const currentPanel = allPanels.find((panel) => panel.dataset.questionState === 'active');

    clearTransitionTimer();

    allPanels.forEach((panel) => {
      if (panel === nextPanel) return;
      if (panel.hidden) return;
      if (panel.dataset.questionState === 'active') {
        setPanelState(panel, 'exiting');
      }
    });

    if (currentPanel && currentPanel !== nextPanel && !currentPanel.hidden) {
      setPanelState(currentPanel, 'exiting');
    }

    setPanelState(nextPanel, currentPanel === nextPanel ? 'active' : 'entering');
    nextPanel.hidden = false;

    if (prefersReducedMotion || currentPanel === nextPanel) {
      setPanelState(nextPanel, 'active');
      syncPanelHeight(nextPanel);
      return;
    }

    panels.style.minHeight = `${Math.max(currentPanel?.getBoundingClientRect().height ?? 0, nextPanel.getBoundingClientRect().height)}px`;
    requestAnimationFrame(() => {
      setPanelState(nextPanel, 'active');
    });

    if (currentPanel && currentPanel !== nextPanel) {
      transitionTimer = window.setTimeout(() => {
        setPanelState(currentPanel, 'hidden');
        syncPanelHeight(nextPanel);
      }, 240);
    }
  }

  function renderQuiz(data: QuizRenderData) {
    const activePanel = data.questionId
      ? quizPanels.find((panel) => panel.dataset.quizPanelId === data.questionId)
      : undefined;

    if (!activePanel) return;

    activatePanel(activePanel);
    nav.hidden = false;

    if (stepCurrent) {
      stepCurrent.textContent = String(activePanel.dataset.quizQuestionIndex ?? '1');
    }

    if (stepTotal) {
      stepTotal.textContent = '6';
    }

    const selectedSet = new Set(data.selected);

    activePanel.querySelectorAll<HTMLButtonElement>('[data-quiz-option]').forEach((btn) => {
      const optionId = btn.dataset.optionId ?? '';
      const selected = selectedSet.has(optionId);
      btn.classList.toggle('selected', selected);
      btn.setAttribute('aria-pressed', String(selected));
    });

    const otherBlock = activePanel.querySelector<HTMLElement>('[data-quiz-other]');
    const otherInput = activePanel.querySelector<HTMLInputElement>('[data-quiz-other-input]');
    const showOther = data.hasOther && selectedSet.has('otro');

    if (otherBlock) {
      otherBlock.hidden = !showOther;
    }

    if (otherInput) {
      otherInput.value = data.otherText;
    }

    const errorEl = activePanel.querySelector<HTMLElement>('[data-quiz-error]');
    if (errorEl) {
      errorEl.textContent = data.error;
      errorEl.hidden = !data.error;
      if (data.error) {
        btnContinue.setAttribute('aria-describedby', errorEl.id);
      } else {
        btnContinue.removeAttribute('aria-describedby');
      }
    }

    btnBack.disabled = data.isFirstStep;
    btnContinue.textContent = data.isLastStep ? 'Completar mis datos' : 'Siguiente';
  }

  function renderLeadError(el: HTMLElement, message: string | undefined) {
    if (message) {
      el.textContent = message;
      el.hidden = false;
    } else {
      el.hidden = true;
    }
  }

  function renderLead(data: LeadRenderData) {
    activatePanel(leadPanel);
    nav.hidden = true;

    if (stepCurrent) {
      stepCurrent.textContent = '6';
    }

    if (stepTotal) {
      stepTotal.textContent = '6';
    }

    inputFullName.value = data.fullName;
    inputWhatsapp.value = data.whatsapp;
    inputEmail.value = data.email;
    inputConsent.checked = data.consent;

    renderLeadError(errorFullName, data.errors.fullName);
    renderLeadError(errorWhatsapp, data.errors.whatsapp);
    renderLeadError(errorEmail, data.errors.email);
    renderLeadError(errorConsent, data.errors.consent);

    if (data.submitting) {
      btnSubmit.disabled = true;
      btnSubmit.textContent = 'Enviando…';
      submitErrorEl.hidden = true;
    } else {
      btnSubmit.disabled = false;
      btnSubmit.textContent = 'Finalizar y recibir orientación';
      if (data.submitError) {
        submitErrorEl.textContent = data.submitError;
        submitErrorEl.hidden = false;
      } else {
        submitErrorEl.hidden = true;
      }
    }
  }

  function clearFieldError(field: string): void {
    window.dispatchEvent(new CustomEvent('funnel:clear-lead-error', { detail: { field } }));
  }

  container.addEventListener('click', (event) => {
    const target = event.target as HTMLElement | null;
    const button = target?.closest<HTMLElement>('[data-quiz-option]');
    if (!button) return;

    const optionId = button.dataset.optionId;
    if (!optionId) return;

    window.dispatchEvent(new CustomEvent('funnel:select-answer', { detail: { optionId } }));
  });

  container.addEventListener('input', (event) => {
    const target = event.target as HTMLInputElement | null;
    if (!target?.matches('[data-quiz-other-input]')) return;

    window.dispatchEvent(
      new CustomEvent('funnel:other-text', { detail: { text: target.value } }),
    );
  });

  window.addEventListener('funnel:render-quiz', ((e: CustomEvent<QuizRenderData>) => {
    renderQuiz(e.detail);
  }) as EventListener);

  window.addEventListener('funnel:render-lead', ((e: CustomEvent<LeadRenderData>) => {
    renderLead(e.detail);
  }) as EventListener);

  inputFullName.addEventListener('input', () => {
    clearFieldError('fullName');
    window.dispatchEvent(new CustomEvent('funnel:update-lead', {
      detail: { field: 'fullName', value: inputFullName.value },
    }));
  });

  inputWhatsapp.addEventListener('input', () => {
    clearFieldError('whatsapp');
    window.dispatchEvent(new CustomEvent('funnel:update-lead', {
      detail: { field: 'whatsapp', value: inputWhatsapp.value },
    }));
  });

  inputEmail.addEventListener('input', () => {
    clearFieldError('email');
    window.dispatchEvent(new CustomEvent('funnel:update-lead', {
      detail: { field: 'email', value: inputEmail.value },
    }));
  });

  inputConsent.addEventListener('change', () => {
    clearFieldError('consent');
    window.dispatchEvent(new CustomEvent('funnel:update-lead', {
      detail: { field: 'consent', value: inputConsent.checked },
    }));
  });

  leadForm.addEventListener('submit', (event) => {
    event.preventDefault();
    window.dispatchEvent(new CustomEvent('funnel:submit-lead'));
  });

  btnContinue.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('funnel:continue'));
  });

  btnBack.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('funnel:back'));
  });
</script>

<style>
  .quiz-step {
    position: relative;
    width: min(100%, 1080px);
    margin: clamp(1.5rem, 4vw, 2.75rem) auto 0;
    padding: 0 clamp(1rem, 2.4vw, 1.5rem) clamp(1.25rem, 2.5vw, 1.75rem);
    border: 0;
    background: transparent;
    box-shadow: none;
    scroll-margin-top: clamp(1rem, 4vw, 2rem);
  }

  .quiz-shell {
    display: grid;
    justify-items: center;
    gap: clamp(0.9rem, 1.8vw, 1.2rem);
  }

  .quiz-intro {
    display: grid;
    justify-items: start;
    gap: 0.55rem;
    width: 100%;
    max-width: 760px;
    margin: 0;
    text-align: left;
  }

  .quiz-kicker {
    margin: 0;
    font-size: 0.78rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--via-rust, #b46430);
  }

  .quiz-intro-heading {
    margin: 0;
    max-width: 18ch;
    color: var(--via-night-blue);
    font-size: clamp(1.6rem, 3vw, 2.45rem);
    line-height: 1.06;
    letter-spacing: -0.028em;
  }

  .quiz-intro-body {
    margin: 0;
    max-width: 50ch;
    color: var(--via-gray-600);
    font-size: clamp(0.95rem, 1.4vw, 1.03rem);
    line-height: 1.58;
  }

  .quiz-intro-body-secondary {
    max-width: 58ch;
  }

  .quiz-intro-body-tertiary {
    max-width: 54ch;
    color: var(--via-night-blue);
    font-weight: var(--fw-semibold);
  }

  .quiz-card {
    display: grid;
    gap: clamp(0.85rem, 1.8vw, 1.15rem);
    width: 100%;
    max-width: 980px;
    margin: 0;
    padding: clamp(1rem, 2vw, 1.35rem);
    border-radius: 30px;
    border: 1px solid rgba(227, 219, 208, 0.95);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.92) 0%, rgba(251, 247, 242, 0.96) 100%);
    box-shadow:
      0 18px 40px rgba(26, 39, 68, 0.05),
      inset 0 1px 0 rgba(255, 255, 255, 0.85);
  }

  .quiz-card-top {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.8rem;
  }

  .quiz-card-eyebrow {
    margin: 0;
    font-size: 0.76rem;
    font-weight: var(--fw-bold);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--via-night-blue);
  }

  .quiz-progress-wrap {
    width: 100%;
    max-width: 290px;
  }

  .quiz-progress-wrap :global(.progress) {
    justify-items: end;
    gap: 0.35rem;
    margin-bottom: 0;
    padding: 0;
    border: 0;
    background: transparent;
    box-shadow: none;
  }

  .quiz-progress-wrap :global(.progress-meta) {
    display: none;
  }

  .quiz-progress-wrap :global(.progress-track) {
    justify-content: flex-end;
    gap: 0.35rem;
  }

  .quiz-progress-wrap :global(.progress-dot) {
    width: 0.38rem;
    height: 0.38rem;
    border: 0;
    background: rgba(217, 209, 192, 0.7);
    box-shadow: none;
  }

  .quiz-progress-wrap :global(.progress-dot[aria-current='step']) {
    width: 1.55rem;
    background: #d58a34;
    box-shadow: none;
    transform: none;
  }

  .quiz-progress-wrap :global(.progress-dot.progress-done) {
    background: rgba(213, 138, 52, 0.85);
  }

  .quiz-panels {
    display: grid;
    width: 100%;
  }

  .quiz-question-stage {
    display: grid;
    grid-template-areas: 'stack';
    width: 100%;
    overflow: clip;
  }

  .quiz-panel {
    display: block;
    grid-area: stack;
    width: 100%;
    transition:
      opacity 240ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 240ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .quiz-panel[data-question-state='entering'] {
    opacity: 0;
    transform: translateY(14px);
  }

  .quiz-panel[data-question-state='active'] {
    opacity: 1;
    transform: translateY(0);
    z-index: 1;
  }

  .quiz-panel[data-question-state='exiting'] {
    opacity: 0;
    transform: translateY(-10px);
    pointer-events: none;
  }

  .quiz-panel[hidden] {
    display: none !important;
  }

  .quiz-question-copy {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    width: 100%;
    padding: 0;
  }

  .quiz-question-copy-lead {
    align-items: stretch;
    padding: 0;
  }

  .quiz-question {
    font-family: var(--ff-heading);
    font-size: clamp(1.2rem, 1.85vw, 1.7rem);
    text-align: left;
    margin: 0 0 0.45rem;
    max-width: 24ch;
    outline: none;
    color: var(--via-night-blue);
    line-height: 1.16;
  }

  .quiz-question-support {
    margin: 0 0 1rem;
    font-size: 0.95rem;
    color: var(--via-rust, #9a5a39);
    max-width: 56ch;
    line-height: 1.6;
    text-align: left;
  }

  .quiz-options {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 0.7rem;
    width: 100%;
    margin-bottom: 0.75rem;
  }

  @media (min-width: 860px) {
    .quiz-options {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.8rem;
    }

    .quiz-option {
      min-height: 68px;
      align-items: flex-start;
    }
  }

  .quiz-option {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    width: 100%;
    gap: 1rem;
    min-height: 60px;
    padding: 0.88rem 0.98rem;
    font-family: var(--ff-body);
    font-size: 0.96rem;
    text-align: left;
    color: #7b4b44;
    background: rgba(255, 255, 255, 0.68);
    border: 1px solid rgba(231, 222, 213, 0.96);
    border-radius: 19px;
    box-shadow:
      0 8px 20px rgba(26, 39, 68, 0.03),
      inset 0 1px 0 rgba(255, 255, 255, 0.78);
    cursor: pointer;
    transition:
      border-color var(--transition-base),
      background var(--transition-base),
      box-shadow var(--transition-base),
      color var(--transition-base),
      transform var(--transition-base);
  }

  .quiz-option::after {
    content: '';
    flex: none;
    order: -1;
    width: 1.15rem;
    height: 1.15rem;
    border-radius: 999px;
    border: 1.5px solid rgba(219, 207, 197, 0.95);
    background: rgba(255, 255, 255, 0.96);
    box-shadow:
      inset 0 0 0 2px rgba(255, 255, 255, 0.4),
