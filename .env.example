PUBLIC_FUNNEL_API_URL=/api/funnel-submissions
# Google Apps Script Web App URL (deployed from the Apps Script editor)
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
# Shared secret for request authentication (optional but recommended)
GOOGLE_APPS_SCRIPT_SECRET=your-shared-secret
# Set to "true" only when running behind a trusted reverse proxy that
# overwrites x-forwarded-for / x-real-ip. Otherwise leave unset.
TRUST_PROXY_HEADERS=
